{
  "name": "my-v0-project",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "db:generate": "prisma generate --config prisma.config.ts",
    "db:generate:outbox": "node scripts/build-outbox-prisma-schema.mjs && prisma generate --config prisma.outbox.config.ts",
    "db:push": "prisma db push --accept-data-loss --config prisma.config.ts",
    "db:migrate": "prisma migrate dev --config prisma.config.ts",
    "db:deploy": "prisma migrate deploy --config prisma.config.ts",
    "db:resolve": "prisma migrate resolve --config prisma.config.ts",
    "db:push:outbox": "node scripts/build-outbox-prisma-schema.mjs && prisma db push --accept-data-loss --config prisma.outbox.config.ts",
    "db:seed": "npx tsx prisma/seed.ts",
    "outbox:smoke": "tsx scripts/outbox-smoke.ts",
    "outbox:seed:biomarker": "tsx scripts/seed-outbox-biomarker.ts",
    "outbox:dispatch": "tsx scripts/outbox-dispatch.ts",
    "outbox:dispatch:kafka": "cross-env OUTBOX_BROKER=kafka tsx scripts/outbox-dispatch.ts",
    "outbox:dispatch:pubsub": "cross-env OUTBOX_BROKER=pubsub tsx scripts/outbox-dispatch.ts",
    "outbox:worker": "tsx scripts/outbox-worker.ts",
    "outbox:worker:kafka": "cross-env OUTBOX_BROKER=kafka tsx scripts/outbox-worker.ts",
    "outbox:worker:pubsub": "cross-env OUTBOX_BROKER=pubsub tsx scripts/outbox-worker.ts",
    "jobs:dispatch": "tsx scripts/orchestration-dispatch.ts",
    "jobs:worker": "tsx scripts/orchestration-worker.ts",
    "jobs:retention": "tsx scripts/orchestration-retention.ts",
    "jobs:worker:once": "tsx scripts/orchestration-dispatch.ts",
    "audit:ai": "tsx scripts/audit-age-defy-ai.ts",
    "bench": "tsx scripts/run-bench.ts",
    "build": "next build",
    "dev": "next dev",
    "lint": "next lint",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "test": "pnpm test:unit && pnpm test:integration",
    "test:unit": "vitest run --exclude __tests__/jwt-for-tests-integration.test.ts --exclude __tests__/mechanistic-models-api.test.ts",
    "test:integration": "vitest run __tests__/jwt-for-tests-integration.test.ts __tests__/mechanistic-models-api.test.ts __tests__/scientist-sponsor-marketplace-integration.test.ts",
    "test:watch": "vitest"
  },
