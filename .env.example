# Populate live provider credentials from your deployment secret store before enabling production traffic.

# ÆonForge Integration (Pharmaceutical Superintelligence Platform)
AEONFORGE_API_ENDPOINT=""
AEONFORGE_API_KEY=""
AEONFORGE_TIMEOUT_MS="300000"
AEONFORGE_MAX_RETRIES="2"

# Outbox broker runtime
OUTBOX_BROKER="kafka"
OUTBOX_BATCH_SIZE="100"
OUTBOX_POLL_INTERVAL_MS="5000"
OUTBOX_MAX_ATTEMPTS="5"
OUTBOX_RETRY_DELAY_MS="30000"
OUTBOX_TENANT_ID=""

# Durable orchestration worker runtime
JOB_WORKER_BATCH_SIZE="50"
JOB_WORKER_POLL_INTERVAL_MS="3000"
JOB_WORKER_MAX_ATTEMPTS="8"
JOB_WORKER_RETRY_DELAY_MS="15000"
JOB_WORKER_LEASE_MS="120000"
JOB_RETENTION_HOURS="168"
JOB_TENANT_ID=""

# Kafka broker configuration
KAFKA_BROKERS="localhost:9092"
KAFKA_CLIENT_ID="agedefy-outbox-worker"
KAFKA_SSL="false"
KAFKA_SASL_MECHANISM="plain"
KAFKA_SASL_USERNAME=""
KAFKA_SASL_PASSWORD=""

# Google Pub/Sub broker configuration
