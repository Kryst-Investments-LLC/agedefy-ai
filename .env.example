# Runtime identity. Production/staging enable fail-closed baseline validation.
APP_ENV="development" # development | test | staging | production
RUNTIME_REQUIREMENTS_ENFORCED="false"
PRISMA_RUNTIME="postgres"

# PostgreSQL only. Use separate least-privilege application and migration users
# in production. Never commit real credentials.
DATABASE_URL="postgresql://agedefy_app:change-me@127.0.0.1:5432/agedefy"
POSTGRES_DATABASE_URL="postgresql://agedefy_app:change-me@127.0.0.1:5432/agedefy"
POSTGRES_SHADOW_DATABASE_URL=""
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="development-secret-change-me-before-production-32c" # Replace with a real secret ≥32 chars in production
MFA_ENCRYPTION_KEY="development-mfa-key-change-before-production-32c"
MFA_ALLOW_PLAINTEXT_FALLBACK="false"
ENABLE_TEST_AUTH_ENDPOINT="false" # Keep false outside isolated test environments.
ADMIN_EMAILS=""
CRON_SECRET=""

# Shared production rate limiting and short-lived coordination.
REDIS_URL=""
REDIS_TOKEN=""

# OpenTelemetry export is required by the staging/production baseline.
OTEL_SERVICE_NAME="biozephyra-ai"
OTEL_EXPORTER_OTLP_ENDPOINT=""

# Tenant and AI governance defaults. Tighten these for the approved launch scope.
TENANCY_MODE="single"
DEFAULT_TENANT_ID="default"
AI_GOVERNANCE_ENFORCED="true"
AI_REQUIRE_AUTH="true"
AI_ALLOWED_MODELS=""
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_GRAPH_PRICE_ID=""
OPENAI_API_KEY=""
ANTHROPIC_API_KEY=""
GROK_API_KEY=""
NEXT_PUBLIC_ENABLE_AI_FEATURES="true"
NEXT_PUBLIC_ENABLE_CHATGPT="true"
NEXT_PUBLIC_ENABLE_GROK="false"
NEXT_PUBLIC_ENABLE_ANTHROPIC="true"
NEXT_PUBLIC_ENABLE_PUBMED_API="true"
NEXT_PUBLIC_ENABLE_CLINICAL_TRIALS_API="true"
NEXT_PUBLIC_ENABLE_BIOMARKER_API="true"
NEXT_PUBLIC_ENABLE_REAL_TIME_DATA="false"
NEXT_PUBLIC_ENABLE_LIVE_ANALYTICS="true"
NEXT_PUBLIC_ENABLE_DYNAMIC_RECOMMENDATIONS="true"
NEXT_PUBLIC_USE_MOCK_DATA="false"
NEXT_PUBLIC_DEBUG_MODE="false"
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
EMAIL_FROM="noreply@agedefy.ai"

# Encrypts credentials for user-registered external screening adapters.
# Use a dedicated, independently rotated secret from the deployment vault.
SCREENING_ADAPTER_ENCRYPTION_KEY=""
SCREENING_ADAPTER_ALLOW_PLAINTEXT="false"

# Populate live provider credentials from your deployment secret store before enabling production traffic.

# PubChem PUG REST (public NCBI API — no key required)
# PUBCHEM_BASE_URL="https://pubchem.ncbi.nlm.nih.gov/rest/pug"  # override for proxy or test stubs
PUBCHEM_TIMEOUT_MS="10000"
PUBCHEM_CACHE_TTL_MS="3600000"  # 1 hour in-process TTL; PubChem data is stable

# ChEMBL REST (public EBI API — no key required)
# CHEMBL_BASE_URL="https://www.ebi.ac.uk/chembl/api/data"  # override for proxy or test stubs
CHEMBL_TIMEOUT_MS="15000"
CHEMBL_CACHE_TTL_MS="3600000"   # 1 hour in-process TTL
CHEMBL_MAX_ACTIVITIES="200"     # max bioactivities fetched per compound lookup

# RCSB PDB (public API — no key required)
# PDB_METADATA_BASE_URL="https://data.rcsb.org/rest/v1/core/entry"  # override for proxy
# PDB_FILES_BASE_URL="https://files.rcsb.org/download"              # override for proxy
PDB_TIMEOUT_MS="30000"           # structure files can be several MB
PDB_CACHE_TTL_MS="86400000"      # 24 h in-memory metadata TTL; PDB entries are stable
PDB_STRUCTURE_CACHE_DIR="data/pdb-structures"  # disk cache for .cif / .pdb files

# ÆonForge Integration (AI-Assisted Discovery Platform)
AEONFORGE_API_ENDPOINT=""
AEONFORGE_API_KEY=""
AEONFORGE_TIMEOUT_MS="300000"
AEONFORGE_MAX_RETRIES="2"

# Outbox broker runtime
OUTBOX_BROKER="kafka"
OUTBOX_BATCH_SIZE="100"
OUTBOX_POLL_INTERVAL_MS="5000"
OUTBOX_MAX_ATTEMPTS="5"
OUTBOX_RETRY_DELAY_MS="30000"
OUTBOX_TENANT_ID=""

# Durable orchestration worker runtime
JOB_WORKER_BATCH_SIZE="50"
JOB_WORKER_POLL_INTERVAL_MS="3000"
JOB_WORKER_MAX_ATTEMPTS="8"
JOB_WORKER_RETRY_DELAY_MS="15000"
JOB_WORKER_LEASE_MS="120000"
JOB_RETENTION_HOURS="168"
JOB_TENANT_ID=""

# Kafka broker configuration
KAFKA_BROKERS="localhost:9092"
KAFKA_CLIENT_ID="agedefy-outbox-worker"
KAFKA_SSL="false"
KAFKA_SASL_MECHANISM="plain"
KAFKA_SASL_USERNAME=""
KAFKA_SASL_PASSWORD=""

# Google Pub/Sub broker configuration
PUBSUB_PROJECT_ID=""
PUBSUB_API_ENDPOINT=""
GOOGLE_APPLICATION_CREDENTIALS=""

# ─── Experimental / in-development feature gates ────────────────────────────
# These default OFF (absent = false). Set to "true" only when the feature is
# production-ready and all dependencies (sidecars, infra) are in place.
ENABLE_FEDERATED_LEARNING="false"  # Federated Learning (DP-SGD, Flower microservice). Flag: ENABLE_FEDERATED_LEARNING
ENABLE_CAUSAL_SIDECAR="false"      # Causal-inference sidecar routes (/api/agents/causal-inference/*). Flag: ENABLE_CAUSAL_SIDECAR
ENABLE_NEO4J_BACKEND="false"       # Neo4j knowledge-graph backend (also requires KG_BACKEND=neo4j). Flag: ENABLE_NEO4J_BACKEND
ENABLE_SCREENING_SIDECAR="false"
ENABLE_OPENMM_SIDECAR="false"
ENABLE_FEP_SIDECAR="false"
FL_SERVER_URL=""
SCREENING_SIDECAR_URL=""
OPENMM_SIDECAR_URL=""
FEP_SIDECAR_URL=""

# ─── Sidecar services ───────────────────────────────────────
# Internal microservices for causal inference, differential-privacy budgeting,
# and Verifiable Credential issuance. Defaults assume in-cluster service DNS;
# override with public Fly.io URLs when running outside the mesh.
CAUSAL_SIDECAR_URL="https://agedefy-causal-sidecar.fly.dev"
CAUSAL_SIDECAR_TIMEOUT_MS="20000"
DP_ACCOUNTANT_URL="https://agedefy-dp-accountant.fly.dev"
DP_ACCOUNTANT_TIMEOUT_MS="10000"
VC_SIGNER_URL="https://agedefy-vc-signer.fly.dev"
VC_SIGNER_TIMEOUT_MS="10000"
VC_ISSUER_DID="did:web:vc.agedefy.ai"

# Mechanistic simulation sidecar (T3 / digital-twin-agent). Leave blank to use
# the deterministic in-process exponential-relaxation fallback simulator.
MECHANISTIC_SIDECAR_URL=""

# ─── Wearables ─────────────────────────────────────────────
# Terra is the multi-provider broker (Garmin, Oura, Whoop, Fitbit, Withings, …).
TERRA_API_KEY=""
TERRA_DEV_ID=""
TERRA_WEBHOOK_SECRET=""

# Dexcom direct CGM adapter (T1.14). Sandbox by default.
DEXCOM_CLIENT_ID=""
DEXCOM_CLIENT_SECRET=""
DEXCOM_REDIRECT_URI="http://localhost:3000/api/wearables/dexcom/callback"
DEXCOM_API_HOST="https://sandbox-api.dexcom.com"

# Shared bearer for scheduled wearable sync jobs hitting /api/wearables/dexcom/sync
WEARABLE_SYNC_TOKEN=""

# ─── Lab report OCR (T1.15) ────────────────────────────────
# Provider for PDF/image lab report transcription. Leave blank to auto-pick
# "openai-vision" when OPENAI_API_KEY is set, or "noop" otherwise.
LAB_OCR_PROVIDER=""
LAB_OCR_OPENAI_MODEL="gpt-4o-mini"
