{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "Request Rate (req/s)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(biozephyra_http_request_duration_ms_count[5m]))",
          "legendFormat": "All routes"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps" }
      }
    },
    {
      "title": "Error Rate (4xx + 5xx)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(biozephyra_http_request_duration_ms_count{http_status_code=~\"4..|5..\"}[5m])) / sum(rate(biozephyra_http_request_duration_ms_count[5m])) * 100",
          "legendFormat": "Error %"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "percent", "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 1 }, { "color": "red", "value": 5 }] } }
      }
    },
    {
      "title": "Latency Percentiles (ms)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        { "expr": "histogram_quantile(0.50, sum(rate(biozephyra_http_request_duration_ms_bucket[5m])) by (le))", "legendFormat": "p50" },
        { "expr": "histogram_quantile(0.95, sum(rate(biozephyra_http_request_duration_ms_bucket[5m])) by (le))", "legendFormat": "p95" },
        { "expr": "histogram_quantile(0.99, sum(rate(biozephyra_http_request_duration_ms_bucket[5m])) by (le))", "legendFormat": "p99" }
      ],
      "fieldConfig": {
        "defaults": { "unit": "ms" }
      }
    },
    {
      "title": "Rate Limit Blocks",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        { "expr": "sum(rate(biozephyra_rate_limit_blocked_count[5m])) by (route)", "legendFormat": "{{ route }}" }
      ]
    },
    {
      "title": "Rate Limit Abuse Detections",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 16 },
      "targets": [
        { "expr": "sum(increase(biozephyra_rate_limit_abuse_count[1h]))", "legendFormat": "Abuses (1h)" }
      ]
    }
  ],
  "schemaVersion": 39,
  "tags": ["biozephyra", "platform"],
  "templating": { "list": [] },
  "time": { "from": "now-6h", "to": "now" },
  "title": "biozephyra — Platform Health",
  "uid": "biozephyra-platform-health"
}
