  "panels": [
    {
      "title": "AI Requests by Provider",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        { "expr": "sum(rate(biozephyra_ai_request_count[5m])) by (provider)", "legendFormat": "{{ provider }}" }
      ]
    },
    {
      "title": "AI Cost (USD/hour)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        { "expr": "sum(rate(biozephyra_ai_request_cost_usd_sum[1h])) by (provider) * 3600", "legendFormat": "{{ provider }}" }
      ],
      "fieldConfig": { "defaults": { "unit": "currencyUSD" } }
    },
    {
      "title": "AI Latency p95 (ms)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        { "expr": "histogram_quantile(0.95, sum(rate(biozephyra_ai_request_latency_ms_bucket[5m])) by (le, provider))", "legendFormat": "{{ provider }} p95" }
      ],
      "fieldConfig": { "defaults": { "unit": "ms" } }
    },
    {
      "title": "Circuit Breaker State Changes",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        { "expr": "sum(increase(biozephyra_circuit_breaker_state_change_count[5m])) by (dependency, state)", "legendFormat": "{{ dependency }} → {{ state }}" }
      ]
    },
    {
      "title": "Token Usage by Provider",
      "type": "bargauge",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 16 },
      "targets": [
        { "expr": "sum(increase(biozephyra_ai_request_cost_usd_count[24h])) by (provider)", "legendFormat": "{{ provider }}" }
      ]
    }
  ],
