{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agedefy.ai/schemas/legal-rule.schema.json",
  "title": "AgeDefy Legal-Rules File",
  "type": "object",
  "required": ["jurisdiction", "applies_to", "legal_domains", "rules", "last_reviewed"],
  "additionalProperties": true,
  "properties": {
    "jurisdiction": {
      "type": "object",
      "required": ["code", "name"],
      "properties": {
        "code":   { "type": "string", "pattern": "^[a-z]{2}(-[a-z0-9]{2,3})?$" },
        "name":   { "type": "string", "minLength": 2 },
        "parent": { "type": "string" }
      }
    },
    "applies_to":    { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "legal_domains": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "last_reviewed": { "type": "string", "format": "date" },
    "rules": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "description", "severity", "category", "when", "then", "citations"],
        "properties": {
          "id":          { "type": "string", "pattern": "^[a-z0-9_.-]+$" },
          "description": { "type": "string", "minLength": 10 },
          "severity":    { "enum": ["low", "medium", "high", "critical"] },
          "category":    { "type": "string" },
          "when":        { "type": "array", "minItems": 1, "items": { "type": "string" } },
          "then":        { "type": "array", "minItems": 1, "items": { "type": "string" } },
          "citations":   {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["title", "url"],
              "properties": {
                "title": { "type": "string" },
                "url":   { "type": "string", "format": "uri" }
              }
            }
          }
        }
      }
    },
    "notes": { "type": "string" }
  }
}
