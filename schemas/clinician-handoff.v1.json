{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agedefy.ai/schemas/clinician-handoff.v1.json",
  "title": "AgeDefy Clinician Handoff Packet (v1)",
  "description": "Structured JSON case packet handed to a licensed clinician for human-in-the-loop review — NOT a chat transcript. Referenced by agents/clinician-review-agent.yml (structured_handoff.schema_ref). The four core sections are required because a defensible review cannot proceed without patient context, the AI's assessment, the risk signals that triggered the handoff, and the governing jurisdiction.",
  "type": "object",
  "required": ["patient_summary", "ai_assessment", "risk_signals", "jurisdiction_context"],
  "additionalProperties": false,
  "properties": {
    "patient_summary": {
      "type": "object",
      "required": ["active_interventions", "adherence_pct"],
      "additionalProperties": false,
      "properties": {
        "biomarkers_latest_panel": {
          "type": "object",
          "description": "Most recent lab panel as a biomarker -> value map.",
          "additionalProperties": true
        },
        "wearable_30d_window": {
          "type": "object",
          "description": "Aggregated wearable signals over the trailing 30 days.",
          "additionalProperties": true
        },
        "active_interventions": {
          "type": "array",
          "items": { "type": "object", "additionalProperties": true }
        },
        "adherence_pct": { "type": "number", "minimum": 0, "maximum": 100 }
      }
    },
    "ai_assessment": {
      "type": "object",
      "required": ["recommendation", "confidence"],
      "additionalProperties": false,
      "properties": {
        "recommendation": { "type": "object", "additionalProperties": true },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "cited_evidence": {
          "type": "array",
          "description": "Provenance for the recommendation (paper/trial references).",
          "items": { "type": "object", "additionalProperties": true }
        },
        "causal_estimate_id": { "type": "string" },
        "digital_twin_simulation_id": { "type": "string" },
        "falsification_passed": { "type": "boolean" }
      }
    },
    "risk_signals": {
      "type": "object",
      "required": ["risk_class"],
      "additionalProperties": false,
      "properties": {
        "risk_class": { "type": "string", "enum": ["low", "medium", "high", "critical"] },
        "triggered_safety_rules": { "type": "array", "items": { "type": "string" } },
        "compound_interactions": {
          "type": "array",
          "items": { "type": "object", "additionalProperties": true }
        }
      }
    },
    "jurisdiction_context": {
      "type": "object",
      "required": ["user_jurisdiction"],
      "additionalProperties": false,
      "properties": {
        "user_jurisdiction": { "type": "string" },
        "applicable_legal_rule_set_version": { "type": "string" },
        "required_disclosures": { "type": "array", "items": { "type": "string" } }
      }
    },
    "vc_chain": {
      "type": "object",
      "description": "Optional verifiable-credential references backing the assessment.",
      "additionalProperties": false,
      "properties": {
        "recommendation_vc": { "type": "string" },
        "omics_ingestion_receipt_vc": { "type": "string" },
        "n_of_1_trial_result_vc": { "type": "string" }
      }
    }
  }
}
