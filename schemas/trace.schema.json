{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agedefy.ai/schemas/trace.schema.json",
  "title": "AgeDefy Orchestrator Trace Record (one per JSONL line)",
  "type": "object",
  "required": ["runId", "ts", "agent", "intent", "decision", "latencyMs"],
  "properties": {
    "runId":        { "type": "string", "pattern": "^[0-9a-f-]{8,}$" },
    "ts":           { "type": "string", "format": "date-time" },
    "agent":        { "type": "string" },
    "intent":       { "type": "string" },
    "workflow":     { "type": "string" },
    "step":         { "type": "string" },
    "decision":     { "enum": ["allow", "warn", "block", "ok", "error"] },
    "jurisdiction": { "type": "string" },
    "latencyMs":    { "type": "integer", "minimum": 0 },
    "errorCode":    { "type": "string" },
    "reasons":      { "type": "array", "items": { "type": "string" } }
  },
  "additionalProperties": true
}
