{
  "dashboard": {
    "title": "biozephyra API Overview",
    "uid": "biozephyra-api-overview",
    "tags": ["biozephyra", "api", "slo"],
    "timezone": "utc",
    "refresh": "30s",
    "panels": [
      {
        "title": "API Request Rate",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
        "targets": [
          {
            "expr": "sum(rate(http_request_duration_ms_count[5m])) by (route)",
            "legendFormat": "{{ route }}"
          }
        ]
      },
      {
        "title": "Error Rate (5xx)",
        "type": "stat",
        "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
        "targets": [
          {
            "expr": "sum(rate(http_request_duration_ms_count{http_status_code=~\"5..\"}[5m])) / sum(rate(http_request_duration_ms_count[5m]))",
            "legendFormat": "Error Rate"
          }
        ],
        "fieldConfig": {
          "defaults": { "unit": "percentunit", "thresholds": { "steps": [{"value": 0, "color": "green"}, {"value": 0.005, "color": "yellow"}, {"value": 0.01, "color": "red"}] } }
        }
      },
      {
        "title": "API Availability (30d)",
        "type": "stat",
        "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
        "targets": [
          {
            "expr": "1 - (sum(increase(http_request_duration_ms_count{http_status_code=~\"5..\"}[30d])) / sum(increase(http_request_duration_ms_count[30d])))",
            "legendFormat": "Availability"
          }
        ],
        "fieldConfig": {
          "defaults": { "unit": "percentunit", "decimals": 3, "thresholds": { "steps": [{"value": 0, "color": "red"}, {"value": 0.999, "color": "green"}] } }
        }
      },
      {
        "title": "P99 Latency (non-AI routes)",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
        "targets": [
          {
            "expr": "histogram_quantile(0.99, sum(rate(http_request_duration_ms_bucket{route!~\"/api/ai/.*\"}[5m])) by (le))",
            "legendFormat": "P99"
          },
          {
            "expr": "histogram_quantile(0.50, sum(rate(http_request_duration_ms_bucket{route!~\"/api/ai/.*\"}[5m])) by (le))",
            "legendFormat": "P50"
          }
        ],
        "fieldConfig": { "defaults": { "unit": "ms" } }
      },
      {
        "title": "AI Provider Requests",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
        "targets": [
          {
            "expr": "sum(rate(ai_request_count[5m])) by (provider)",
            "legendFormat": "{{ provider }}"
          }
        ]
      },
      {
        "title": "AI Cost (USD/hour)",
        "type": "stat",
        "gridPos": { "h": 4, "w": 6, "x": 12, "y": 12 },
        "targets": [
          {
            "expr": "sum(rate(ai_request_cost_usd_sum[1h])) * 3600",
            "legendFormat": "Cost/hr"
          }
        ],
        "fieldConfig": { "defaults": { "unit": "currencyUSD", "decimals": 4 } }
      },
      {
        "title": "Rate Limit Blocks",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 6, "x": 18, "y": 12 },
        "targets": [
          {
            "expr": "sum(rate(rate_limit_blocked_count[5m])) by (route)",
            "legendFormat": "{{ route }}"
          }
        ]
      },
      {
        "title": "Circuit Breaker State Changes",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
        "targets": [
          {
            "expr": "increase(circuit_breaker_state_change_count[5m])",
            "legendFormat": "{{ dependency }} → {{ state }}"
          }
        ]
      },
      {
        "title": "Orchestration Job Queue Depth",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
        "targets": [
          {
            "expr": "sum(jobs_execution_count{status=\"queued\"}) by (queue)",
            "legendFormat": "{{ queue }}"
          }
        ]
      },
      {
        "title": "Stripe Webhook Events",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
        "targets": [
          {
            "expr": "sum(rate(stripe_webhook_count[5m])) by (event_type)",
            "legendFormat": "{{ event_type }}"
          }
        ]
      },
      {
        "title": "Outbox Dispatch Rate",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
        "targets": [
          {
            "expr": "sum(rate(outbox_dispatch_count[5m])) by (status)",
            "legendFormat": "{{ status }}"
          }
        ]
      }
    ]
  }
}
