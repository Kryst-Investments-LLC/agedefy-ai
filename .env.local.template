# AgeDefy AI Environment Variables Template
# Copy this file to .env.local and fill in your actual values

# =============================================================================
# AI FEATURES CONFIGURATION
# =============================================================================

# Master switch for all AI features
NEXT_PUBLIC_ENABLE_AI_FEATURES=false

# Individual AI provider toggles
NEXT_PUBLIC_ENABLE_CHATGPT=false
NEXT_PUBLIC_ENABLE_GROK=false
NEXT_PUBLIC_ENABLE_ANTHROPIC=false

# =============================================================================
# AI API KEYS (REQUIRED FOR PRODUCTION)
# =============================================================================

# OpenAI API Key - Get from https://platform.openai.com/
# Format: sk-...
OPENAI_API_KEY=your_openai_api_key_here

# Grok API Key - Get from https://x.ai/
GROK_API_KEY=your_grok_api_key_here

# Anthropic API Key - Get from https://console.anthropic.com/
# Format: sk-ant-...
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# =============================================================================
# SCIENTIFIC DATA APIS
# =============================================================================

# PubMed API integration
NEXT_PUBLIC_ENABLE_PUBMED_API=false

# Clinical Trials API integration
NEXT_PUBLIC_ENABLE_CLINICAL_TRIALS_API=false

# Biomarker data API integration
NEXT_PUBLIC_ENABLE_BIOMARKER_API=false

# =============================================================================
# FEATURE FLAGS
# =============================================================================

# Real-time data processing
NEXT_PUBLIC_ENABLE_REAL_TIME_DATA=false

# Live analytics dashboard
NEXT_PUBLIC_ENABLE_LIVE_ANALYTICS=false

# Dynamic AI recommendations
NEXT_PUBLIC_ENABLE_DYNAMIC_RECOMMENDATIONS=false

# =============================================================================
# DEVELOPMENT SETTINGS
# =============================================================================

# Use mock data instead of real AI APIs (recommended for development)
NEXT_PUBLIC_USE_MOCK_DATA=true

# Enable debug mode for detailed logging
NEXT_PUBLIC_DEBUG_MODE=false

# =============================================================================
# PRODUCTION SETTINGS
# =============================================================================

# Set to 'production' for production builds
NODE_ENV=development

# Database connection string (if applicable)
# DATABASE_URL=your_database_connection_string

# JWT secret for authentication (if applicable)
# JWT_SECRET=your_jwt_secret_here

# =============================================================================
# SECURITY SETTINGS
# =============================================================================

# CORS allowed origins (comma-separated)
# ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# Rate limiting settings
# RATE_LIMIT_MAX=100
# RATE_LIMIT_WINDOW_MS=900000

# =============================================================================
# MONITORING AND ANALYTICS
# =============================================================================

# Analytics tracking ID (if applicable)
# NEXT_PUBLIC_GA_TRACKING_ID=your_google_analytics_id

# Error tracking service (if applicable)
# SENTRY_DSN=your_sentry_dsn_here

# =============================================================================
# NOTES
# =============================================================================
# 1. Never commit .env.local to version control
# 2. All API keys should be kept secure and rotated regularly
# 3. Use NEXT_PUBLIC_ prefix only for client-side environment variables
# 4. Server-side variables (API keys) should NOT have NEXT_PUBLIC_ prefix
# 5. Set NEXT_PUBLIC_USE_MOCK_DATA=false only when ready for production
