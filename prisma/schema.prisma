// ─── Telemedicine ───────────────────────────────────────────

enum ConsultationStatus {
  REQUESTED
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  CANCELED
}

enum ConsultationType {
  INITIAL
  FOLLOW_UP
  LAB_REVIEW
  PROTOCOL_REVIEW
}

model TelehealthProvider {
  id              String   @id @default(cuid())
  name            String
  credentials     String   // e.g. "MD, Board Certified Internal Medicine"
  specialty       String   // e.g. "longevity medicine", "endocrinology"
  bio             String?
  licenseStates   String?  // JSON array of states/regions
  acceptingNew    Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  consultations   ConsultationRequest[]
}

model ConsultationRequest {
