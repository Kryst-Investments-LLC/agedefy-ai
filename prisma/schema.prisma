model MarketplaceDealRoom {
  id              String                     @id @default(cuid())
  tenantId        String                     @default("default")
  discoveryId     String
  scientistId     String
  sponsorId       String
  status          MarketplaceDealRoomStatus  @default(OPEN)
  ndaRequired     Boolean                    @default(true)
  ndaAcceptedAt   DateTime?
  agreementStatus MarketplaceAgreementStatus @default(DRAFT)
  agreementTerms  Json
  documentVault   Json
  lastActivityAt  DateTime                   @default(now())
  createdAt       DateTime                   @default(now())
  updatedAt       DateTime                   @updatedAt

  discovery     MarketplaceDiscovery       @relation(fields: [discoveryId], references: [id], onDelete: Cascade)
  scientist     MarketplaceScientist       @relation(fields: [scientistId], references: [id], onDelete: Cascade)
  sponsor       MarketplaceSponsor         @relation(fields: [sponsorId], references: [id], onDelete: Cascade)
