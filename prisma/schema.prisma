// ─── Knowledge Graph: Longevity Science Ontology ─────────────

model Compound {
  id           String       @id @default(cuid())
  name         String       @unique
  aliases      String? // JSON array of alternative names
  category     String // e.g. "peptide", "small-molecule", "supplement", "drug"
  riskCategory RiskCategory @default(GREEN)
  description  String?
  casNumber    String?      @unique
  pubChemCid   String?
  mechanism    String? // brief mechanism of action
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  pathways          CompoundPathway[]
  interactions      CompoundInteraction[]     @relation("CompoundA")
  interactedWith    CompoundInteraction[]     @relation("CompoundB")
  biomarkerEffects  CompoundBiomarkerEffect[]
  studyLinks        CompoundStudyLink[]
  aggregateOutcomes AggregateOutcome[]        @relation("AggregateOutcomeCompound")
}

model Pathway {
  id          String   @id @default(cuid())
  name        String   @unique
  category    String // e.g. "aging", "metabolic", "epigenetic", "inflammatory"
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  compounds CompoundPathway[]
}

model CompoundPathway {
  id         String   @id @default(cuid())
  compoundId String
  pathwayId  String
  effect     String // "activator", "inhibitor", "modulator"
  strength   String? // "strong", "moderate", "weak", "theoretical"
  evidence   String? // free-text evidence summary
  createdAt  DateTime @default(now())

  compound Compound @relation(fields: [compoundId], references: [id], onDelete: Cascade)
  pathway  Pathway  @relation(fields: [pathwayId], references: [id], onDelete: Cascade)

  @@unique([compoundId, pathwayId])
}

enum InteractionSeverity {
  BENEFICIAL
  NEUTRAL
  CAUTION
  DANGEROUS
  UNKNOWN
}

model CompoundInteraction {
  id          String              @id @default(cuid())
  compoundAId String
  compoundBId String
  severity    InteractionSeverity @default(UNKNOWN)
  description String?
  source      String? // citation or source URL
  createdAt   DateTime            @default(now())

  compoundA Compound @relation("CompoundA", fields: [compoundAId], references: [id], onDelete: Cascade)
  compoundB Compound @relation("CompoundB", fields: [compoundBId], references: [id], onDelete: Cascade)

  @@unique([compoundAId, compoundBId])
}

model CompoundBiomarkerEffect {
  id            String   @id @default(cuid())
  compoundId    String
  biomarkerName String // e.g. "HbA1c", "CRP", "telomere length"
  direction     String // "increase", "decrease", "stabilize"
  magnitude     String? // "significant", "moderate", "mild"
  evidence      String? // summary
  source        String? // citation
  createdAt     DateTime @default(now())

  compound Compound @relation(fields: [compoundId], references: [id], onDelete: Cascade)

  @@index([compoundId])
  @@index([biomarkerName])
}

model CompoundStudyLink {
  id         String   @id @default(cuid())
  compoundId String
  externalId String // PubMed ID, NCT ID, DOI, etc.
  source     String // "pubmed", "clinicaltrials", "doi"
  title      String?
  url        String?
  createdAt  DateTime @default(now())

  compound Compound @relation(fields: [compoundId], references: [id], onDelete: Cascade)

  @@unique([compoundId, source, externalId])
}

// ─── Mechanistic Model Registry ────────────────────────────

model MechanisticModel {
  id          String   @id @default(cuid())
  tenantId    String   @default("default")
  name        String
  description String?
  version     String // e.g. "v1.0.0"
  source      String? // e.g. "manual", "imported", "AI-generated"
  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  createdBy        User?                  @relation("UserCreatedMechanisticModels", fields: [createdById], references: [id], onDelete: SetNull)
  confidenceScores ModelConfidenceScore[]

  @@unique([name, version])
}

model ModelConfidenceScore {
  id                 String   @id @default(cuid())
  mechanisticModelId String
  entityType         String // e.g. "Hypothesis", "Protocol", "Cohort", etc.
  entityId           String // ID of the entity the score applies to
  score              Float // Confidence score (0-1)
  rationale          String?
  version            String // Model version used for this score
  createdAt          DateTime @default(now())

  mechanisticModel MechanisticModel @relation(fields: [mechanisticModelId], references: [id], onDelete: Cascade)

  @@index([entityType, entityId])
  @@index([mechanisticModelId, version])
}

