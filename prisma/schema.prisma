  PEPTIDE
  TEST_KIT
  DEVICE
  BUNDLE
}

enum MarketplaceOrderStatus {
  PENDING
  PAID
  SHIPPED
  DELIVERED
  CANCELED
  REFUNDED
}

model Product {
  id              String          @id @default(cuid())
  tenantId        String          @default("default")
  name            String          @unique
  slug            String          @unique
  category        ProductCategory @default(SUPPLEMENT)
  description     String?
  ingredients     String?         // JSON array
  priceCents      Int
  currency        String          @default("USD")
  imageUrl        String?
  inStock         Boolean         @default(true)
  thirdPartyTested Boolean        @default(false)
  coaUrl          String?         // certificate of analysis URL
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  orderItems      MarketplaceOrderItem[]
}

model MarketplaceOrder {
  id              String                  @id @default(cuid())
  tenantId        String                  @default("default")
  userId          String
  status          MarketplaceOrderStatus  @default(PENDING)
  totalCents      Int
  currency        String                  @default("USD")
  shippingAddress String?
  trackingNumber  String?
  orderedAt       DateTime                @default(now())
  shippedAt       DateTime?
  deliveredAt     DateTime?
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt

  user            User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  items           MarketplaceOrderItem[]

  @@index([userId, status])
}

model MarketplaceOrderItem {
  id          String   @id @default(cuid())
  orderId     String
  productId   String
  quantity    Int      @default(1)
  priceCents  Int
  createdAt   DateTime @default(now())

  order       MarketplaceOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product     Product          @relation(fields: [productId], references: [id])

  @@index([orderId])
}

model InterventionOutcome {
  id              String    @id @default(cuid())
  tenantId        String    @default("default")
  userId          String
  protocolId      String?
  biomarkerName   String
  baselineValue   Float
  latestValue     Float
  delta           Float
  confidenceScore Float     @default(0.5)
  observedAt      DateTime  @default(now())
  notes           String?
  createdAt       DateTime  @default(now())

  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  protocol        Protocol? @relation(fields: [protocolId], references: [id], onDelete: SetNull)

  @@index([userId, biomarkerName])
  @@index([protocolId])
}

model TrialMatch {
  id              String           @id @default(cuid())
  tenantId        String           @default("default")
  userId          String
  cohortId        String?
  trialExternalId String
  title           String
  condition       String?
  matchScore      Float
  rationale       String
  status          TrialMatchStatus @default(CANDIDATE)
  reviewerId      String?
  reviewNotes     String?
  reviewEvents    TrialMatchReviewEvent[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  user            User             @relation("TrialMatchUser", fields: [userId], references: [id], onDelete: Cascade)
  cohort          PatientCohort?   @relation(fields: [cohortId], references: [id], onDelete: SetNull)
  reviewer        User?            @relation("TrialMatchReviewer", fields: [reviewerId], references: [id], onDelete: SetNull)

  @@index([userId, status])
  @@index([trialExternalId])
  @@index([reviewerId, status])
}

model TrialMatchReviewEvent {
  id             String           @id @default(cuid())
  trialMatchId   String
  actorUserId    String
  eventType      String
  previousStatus TrialMatchStatus?
  nextStatus     TrialMatchStatus?
  notes          String?
  createdAt      DateTime         @default(now())

  trialMatch     TrialMatch       @relation(fields: [trialMatchId], references: [id], onDelete: Cascade)
  actorUser      User             @relation("TrialMatchReviewActor", fields: [actorUserId], references: [id], onDelete: Cascade)

  @@index([trialMatchId, createdAt])
  @@index([actorUserId, eventType])
}

// ─── Scientist Sponsor Marketplace ─────────────────────────

enum MarketplaceDiscoveryStatus {
  DRAFT
  REVIEW
  PUBLISHED
  PRIVATE
  ARCHIVED
}

enum MarketplaceFundingRequestStatus {
  DRAFT
  OPEN
  DUE_DILIGENCE
  COMMITTED
  CLOSED
}

enum MarketplaceDealRoomStatus {
  OPEN
  NEGOTIATING
  AGREEMENT_PENDING
  FUNDED
  CLOSED
}

enum MarketplaceAgreementStatus {
  DRAFT
  REVIEW
  APPROVED
  SIGNED
}

enum MarketplaceMessageType {
  MESSAGE
  DOCUMENT
  AGREEMENT
  PAYMENT
  SYSTEM
}

enum MarketplaceTransactionStatus {
  PENDING
  AUTHORIZED
  SETTLED
  RELEASED
  FAILED
  REFUNDED
}

enum MarketplaceNotificationStatus {
  QUEUED
  DELIVERED
  READ
  DISMISSED
}

model MarketplaceScientist {
  id                      String   @id @default(cuid())
  tenantId                String   @default("default")
  userId                  String   @unique
  displayName             String
  institution             String?
  specialty               String?
  biography               String?
  categories              Json
  fundingStage            String   @default("pre-seed")
  reputationScore         Float    @default(0.45)
  evidenceCount           Int      @default(0)
  publishedDiscoveryCount Int      @default(0)
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  user                    User                     @relation("MarketplaceScientistUser", fields: [userId], references: [id], onDelete: Cascade)
  discoveries             MarketplaceDiscovery[]
  fundingRequests         MarketplaceFundingRequest[]
  matchScores             MarketplaceMatchScore[]
  dealRooms               MarketplaceDealRoom[]

  @@index([fundingStage, reputationScore])
}

model MarketplaceSponsor {
  id                   String   @id @default(cuid())
  tenantId             String   @default("default")
  userId               String   @unique
  organizationId       String?
  organizationName     String
  organizationType     String   @default("venture")
  thesis               String
  preferredCategories  Json
  preferredStages      Json
  maxBudgetCents       Int      @default(250000)
  minImpactScore       Float    @default(0.5)
  capitalAvailableCents Int     @default(1000000)
  dueDiligenceLevel    String   @default("standard")
  geographyFocus       Json
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  user                 User                     @relation("MarketplaceSponsorUser", fields: [userId], references: [id], onDelete: Cascade)
  organization         Organization?            @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  matchScores          MarketplaceMatchScore[]
  dealRooms            MarketplaceDealRoom[]
  transactions         MarketplaceTransaction[]

  @@index([organizationId])
  @@index([maxBudgetCents, minImpactScore])
}

model MarketplaceDiscovery {
  id                   String                     @id @default(cuid())
  tenantId             String                     @default("default")
  scientistId          String
  title                String
  slug                 String                     @unique
  category             String
  summary              String
  developmentStage     String
  status               MarketplaceDiscoveryStatus @default(DRAFT)
  scientificImpactScore Float                     @default(0.5)
  commercialReadiness  Float                      @default(0.4)
  fundingGoalCents     Int                        @default(50000)
  currency             String                     @default("USD")
  evidenceSummary      String?
  evidenceLinks        Json
  metadata             Json
  publishedAt          DateTime?
  createdAt            DateTime                   @default(now())
  updatedAt            DateTime                   @updatedAt

  scientist            MarketplaceScientist       @relation(fields: [scientistId], references: [id], onDelete: Cascade)
  fundingRequest       MarketplaceFundingRequest?
  matchScores          MarketplaceMatchScore[]
  dealRooms            MarketplaceDealRoom[]
  transactions         MarketplaceTransaction[]
  notifications        MarketplaceNotification[]

  @@index([category, status])
  @@index([scientistId, createdAt])
}

model MarketplaceFundingRequest {
  id                   String                          @id @default(cuid())
  tenantId             String                          @default("default")
  discoveryId          String                          @unique
  scientistId          String
  requestedAmountCents Int
  currency             String                          @default("USD")
  useOfFunds           String
  timelineMonths       Int                             @default(12)
  status               MarketplaceFundingRequestStatus @default(DRAFT)
  milestonePlan        Json
  evidenceUploads      Json
  publishedAt          DateTime?
  createdAt            DateTime                        @default(now())
  updatedAt            DateTime                        @updatedAt

  discovery            MarketplaceDiscovery            @relation(fields: [discoveryId], references: [id], onDelete: Cascade)
  scientist            MarketplaceScientist            @relation(fields: [scientistId], references: [id], onDelete: Cascade)

  @@index([scientistId, status])
}

model MarketplaceMatchScore {
  id                   String   @id @default(cuid())
  tenantId             String   @default("default")
  discoveryId          String
  scientistId          String
  sponsorId            String
  overallScore         Float
  ruleBasedScore       Float
  aiAugmentedScore     Float?
  weightedBreakdown    Json
  sponsorPreferenceFit Float    @default(0)
  metadataFit          Float    @default(0)
  rationale            String
  rank                 Int?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  discovery            MarketplaceDiscovery @relation(fields: [discoveryId], references: [id], onDelete: Cascade)
  scientist            MarketplaceScientist @relation(fields: [scientistId], references: [id], onDelete: Cascade)
  sponsor              MarketplaceSponsor   @relation(fields: [sponsorId], references: [id], onDelete: Cascade)

  @@unique([discoveryId, sponsorId])
  @@index([sponsorId, overallScore])
  @@index([scientistId, overallScore])
}

model MarketplaceDealRoom {
  id                   String                     @id @default(cuid())
  tenantId             String                     @default("default")
  discoveryId          String
  scientistId          String
  sponsorId            String
  status               MarketplaceDealRoomStatus  @default(OPEN)
  ndaRequired          Boolean                    @default(true)
  ndaAcceptedAt        DateTime?
  agreementStatus      MarketplaceAgreementStatus @default(DRAFT)
  agreementTerms       Json
  documentVault        Json
  lastActivityAt       DateTime                   @default(now())
  createdAt            DateTime                   @default(now())
  updatedAt            DateTime                   @updatedAt

  discovery            MarketplaceDiscovery       @relation(fields: [discoveryId], references: [id], onDelete: Cascade)
  scientist            MarketplaceScientist       @relation(fields: [scientistId], references: [id], onDelete: Cascade)
  sponsor              MarketplaceSponsor         @relation(fields: [sponsorId], references: [id], onDelete: Cascade)
  messages             MarketplaceMessageThread[]
  transactions         MarketplaceTransaction[]
  auditLogs            MarketplaceAuditLog[]
  notifications        MarketplaceNotification[]

  @@unique([discoveryId, sponsorId])
  @@index([scientistId, status])
  @@index([sponsorId, status])
}

model MarketplaceMessageThread {
  id                   String                 @id @default(cuid())
  tenantId             String                 @default("default")
  dealRoomId           String
  senderUserId         String?
  senderRole           String
  messageType          MarketplaceMessageType @default(MESSAGE)
  body                 String
  attachments          Json
  readAt               DateTime?
  createdAt            DateTime               @default(now())

  dealRoom             MarketplaceDealRoom    @relation(fields: [dealRoomId], references: [id], onDelete: Cascade)
  senderUser           User?                  @relation("MarketplaceMessageSender", fields: [senderUserId], references: [id], onDelete: SetNull)

  @@index([dealRoomId, createdAt])
}

model MarketplaceTransaction {
  id                   String                       @id @default(cuid())
  tenantId             String                       @default("default")
  dealRoomId           String
  discoveryId          String
  sponsorId            String
  amountCents          Int
  currency             String                       @default("USD")
  platformFeeCents     Int                          @default(0)
  transactionFeeCents  Int                          @default(0)
  payoutCents          Int                          @default(0)
  status               MarketplaceTransactionStatus @default(PENDING)
  providerReference    String?
  metadata             Json
  paidAt               DateTime?
  createdAt            DateTime                     @default(now())
  updatedAt            DateTime                     @updatedAt

  dealRoom             MarketplaceDealRoom          @relation(fields: [dealRoomId], references: [id], onDelete: Cascade)
  discovery            MarketplaceDiscovery         @relation(fields: [discoveryId], references: [id], onDelete: Cascade)
  sponsor              MarketplaceSponsor           @relation(fields: [sponsorId], references: [id], onDelete: Cascade)

  @@index([dealRoomId, status])
  @@index([sponsorId, createdAt])
}

model MarketplaceAuditLog {
  id                   String   @id @default(cuid())
  tenantId             String   @default("default")
  dealRoomId           String?
  actorUserId          String?
  actorRole            String
  action               String
  entityType           String
  entityId             String?
  ipAddress            String?
  details              Json
  createdAt            DateTime @default(now())

  dealRoom             MarketplaceDealRoom? @relation(fields: [dealRoomId], references: [id], onDelete: SetNull)
  actorUser            User?                @relation("MarketplaceAuditActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([dealRoomId, createdAt])
  @@index([entityType, entityId])
}

model MarketplaceNotification {
  id                   String                        @id @default(cuid())
  tenantId             String                        @default("default")
  recipientUserId      String
  recipientRole        String
  discoveryId          String?
  dealRoomId           String?
  type                 String
  title                String
  body                 String
  actionUrl            String?
  channels             Json
  status               MarketplaceNotificationStatus @default(QUEUED)
  createdAt            DateTime                      @default(now())
  readAt               DateTime?

  recipientUser        User                          @relation("MarketplaceNotificationRecipient", fields: [recipientUserId], references: [id], onDelete: Cascade)
  discovery            MarketplaceDiscovery?         @relation(fields: [discoveryId], references: [id], onDelete: SetNull)
  dealRoom             MarketplaceDealRoom?          @relation(fields: [dealRoomId], references: [id], onDelete: SetNull)

  @@index([recipientUserId, status])
  @@index([dealRoomId, createdAt])
}

// ─── Trust & Reputation Persistence ────────────────────────

enum TrustRole {
  SCIENTIST
  SPONSOR
  REVIEWER
  CLINICIAN
}

model TrustScore {
  id                    String    @id @default(cuid())
  tenantId              String    @default("default")
  userId                String
  role                  TrustRole
  overallScore          Float     @default(0.5)
  evidenceScore         Float     @default(0.5)
  reviewScore           Float     @default(0.5)
  consistencyScore      Float     @default(0.5)
  reputationScore       Float     @default(0.5)
  engagementScore       Float     @default(0.5)
  computedAt            DateTime  @default(now())
  createdAt             DateTime  @default(now())

  user                  User      @relation("TrustScoreUser", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, role])
  @@index([tenantId, role, overallScore])
}

// ─── Unified Timeline Persistence ──────────────────────────

model TimelineEntry {
  id                String   @id @default(cuid())
  tenantId          String   @default("default")
  userId            String
  domain            String   // biomarker, protocol, lab, consultation, intervention, evidence, marketplace, research, trial, adverse-event
  entityType        String
  entityId          String
  title             String
  summary           String?
  occurredAt        DateTime
  provenanceType    String?  // manual, automated, imported, ai-generated
  provenanceDetail  String?
  reviewStatus      String?  // unreviewed, reviewed, disputed
  createdAt         DateTime @default(now())

  user              User     @relation("TimelineEntryUser", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, domain, occurredAt])
  @@index([tenantId, userId, occurredAt])
  @@index([entityType, entityId])
}

// ─── Feedback Loop & Mission Control Persistence ────────────

model FeedbackLoopSnapshot {
  id                  String   @id @default(cuid())
  tenantId            String   @default("default")
  userId              String
  loopStrength        Float    @default(0)
  discoveryScore      Float    @default(0)
  evaluationScore     Float    @default(0)
  procurementScore    Float    @default(0)
  clinicalReviewScore Float    @default(0)
  interventionScore   Float    @default(0)
  outcomeScore        Float    @default(0)
  fundingScore        Float    @default(0)
  snapshotAt          DateTime @default(now())
  createdAt           DateTime @default(now())

  user                User     @relation("FeedbackLoopUser", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, snapshotAt])
  @@index([tenantId, snapshotAt])
}

// ─── Biological Age Snapshots ──────────────────────────────

model BiologicalAgeSnapshot {
  id                  String   @id @default(cuid())
  tenantId            String   @default("default")
  userId              String
  chronologicalAge    Float
  biologicalAge       Float
  hallmarkScores      String   @default("{}") // JSON: per-hallmark 0-1 scores
  inputSummary        String?  // JSON: biomarkers used for computation
  confidence          Float    @default(0.5)
  createdAt           DateTime @default(now())

  user                User     @relation("BioAgeUser", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([tenantId, userId, createdAt])
}

// ─── Gamification ──────────────────────────────────────────

model UserXP {
  id          String   @id @default(cuid())
  tenantId    String   @default("default")
  userId      String   @unique
  totalXP     Int      @default(0)
  level       Int      @default(1)
  updatedAt   DateTime @updatedAt

  user        User     @relation("UserXPUser", fields: [userId], references: [id], onDelete: Cascade)
}

model UserStreak {
  id            String   @id @default(cuid())
  tenantId      String   @default("default")
  userId        String
  type          String   // daily_login, biomarker_log, protocol_adherence, community
  currentCount  Int      @default(0)
  longestCount  Int      @default(0)
  lastActionAt  DateTime @default(now())
  createdAt     DateTime @default(now())

  user          User     @relation("UserStreakUser", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, type])
  @@index([userId, type])
}

model Achievement {
  id          String   @id @default(cuid())
  code        String   @unique
  title       String
  description String
  icon        String   @default("trophy") // lucide icon name
  category    String   // consistency, knowledge, community, science, health
  threshold   Int      @default(1) // numeric threshold to unlock
  xpReward    Int      @default(0)
  createdAt   DateTime @default(now())

  userAchievements UserAchievement[]
}

model UserAchievement {
  id            String      @id @default(cuid())
  tenantId      String      @default("default")
  userId        String
  achievementId String
  unlockedAt    DateTime    @default(now())

  user          User        @relation("UserAchievementUser", fields: [userId], references: [id], onDelete: Cascade)
  achievement   Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)

  @@unique([userId, achievementId])
  @@index([userId, unlockedAt])
}

// ─── Wearable Connections ──────────────────────────────────

model WearableConnection {
  id            String    @id @default(cuid())
  tenantId      String    @default("default")
  userId        String
  provider      String    // terra, apple_health, garmin, oura, whoop, fitbit
  externalUserId String?  // provider-specific user ID
  scopes        String    @default("[]") // JSON array of granted scopes
  status        String    @default("active") // active, disconnected, error
  connectedAt   DateTime  @default(now())
  lastSyncAt    DateTime?
  createdAt     DateTime  @default(now())

  user          User      @relation("WearableConnectionUser", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, provider])
  @@index([userId, status])
}

// ─── Knowledge Graph Community Contributions ───────────────

model PendingGraphContribution {
  id              String    @id @default(cuid())
  tenantId        String    @default("default")
  contributorId   String
  entityType      String    // pathway-link, interaction, biomarker-effect, study-link
  payload         String    // JSON of the proposed entity data
  status          String    @default("PENDING") // PENDING, APPROVED, REJECTED
  reviewerId      String?
  reviewedAt      DateTime?
  reviewNotes     String?
  createdAt       DateTime  @default(now())

  contributor     User      @relation("GraphContributionUser", fields: [contributorId], references: [id], onDelete: Cascade)

  @@index([status, createdAt])
  @@index([contributorId, status])
}

// ─── AeonForge API-as-a-Service ─────────────────────────────

model APIKey {
  id              String    @id @default(cuid())
  tenantId        String    @default("default")
  userId          String
  name            String    // human label e.g. "Production key"
  prefix          String    // first 8 chars of the raw key (ak_xxxxxxxx) for identification
  keyHash         String    @unique // SHA-256 hash of the full key
  scopes          String    @default("discover,simulate,virtual-twin") // comma-separated
  rateLimitPerMin Int       @default(60)
  sandbox         Boolean   @default(false)
  expiresAt       DateTime?
  revokedAt       DateTime?
  lastUsedAt      DateTime?
  createdAt       DateTime  @default(now())

  user            User      @relation("APIKeyUser", fields: [userId], references: [id], onDelete: Cascade)
  usageRecords    APIUsageRecord[] @relation("APIUsageKey")

  @@index([prefix])
  @@index([userId, revokedAt])
}

model APIUsageRecord {
  id          String   @id @default(cuid())
  keyId       String
  endpoint    String   // e.g. "/v1/aeonforge/discover"
  method      String   @default("POST")
  statusCode  Int
  tokens      Int      @default(0) // AI tokens consumed
  computeMs   Int      @default(0) // execution time in ms
  createdAt   DateTime @default(now())

  apiKey      APIKey   @relation("APIUsageKey", fields: [keyId], references: [id], onDelete: Cascade)

  @@index([keyId, createdAt])
  @@index([createdAt])
}

// ─── Social Sharing & Referrals ─────────────────────────────

model Referral {
  id              String    @id @default(cuid())
  tenantId        String    @default("default")
  referrerId      String
  refereeId       String?   // null until referee signs up
  code            String    @unique // human-readable referral code
  status          String    @default("PENDING") // PENDING, COMPLETED, EXPIRED
  rewardGranted   Boolean   @default(false)
  completedAt     DateTime?
  expiresAt       DateTime?
  createdAt       DateTime  @default(now())

  referrer        User      @relation("ReferralReferrer", fields: [referrerId], references: [id], onDelete: Cascade)
  referee         User?     @relation("ReferralReferee", fields: [refereeId], references: [id], onDelete: SetNull)

  @@index([referrerId, status])
  @@index([code])
}

// ─── Anonymised Outcome Data Flywheel ───────────────────────

model AggregateOutcome {
  id               String   @id @default(cuid())
  tenantId         String   @default("default")
  protocolId       String?
  compoundId       String?
  cohortBucket     String   // e.g. "age:40-49", "all"
  sampleSize       Int
  meanOutcomeScore Float
  stdDev           Float    @default(0)
  pValue           Float?
  confidence       Float    @default(0.5)
  period           String   // e.g. "2025-Q1", "2025-06"
  computedAt       DateTime @default(now())
  createdAt        DateTime @default(now())

  protocol         Protocol? @relation("AggregateOutcomeProtocol", fields: [protocolId], references: [id], onDelete: SetNull)
  compound         Compound? @relation("AggregateOutcomeCompound", fields: [compoundId], references: [id], onDelete: SetNull)

  @@index([protocolId, period])
  @@index([compoundId, period])
  @@index([cohortBucket, computedAt])
}

// ─── Federated Learning ─────────────────────────────────────

model FederatedModel {
  id                String   @id @default(cuid())
  tenantId          String   @default("default")
  version           Int      // monotonically increasing model version
  architecture      String   // e.g. "mlp-3-64", "gbt-100"
  taskType          String   @default("bio-age-delta") // prediction task
  aggregatedFromN   Int      @default(0) // number of clients that contributed
  roundsCompleted   Int      @default(0)
  epsilon           Float?   // total differential privacy budget consumed
  accuracy          Float?   // model accuracy on validation set
  loss              Float?   // model loss on validation set
  metricsJson       String   @default("{}") // JSON: additional eval metrics
  weightsUrl        String?  // URL/path to serialised model weights
  status            String   @default("training") // training, published, deprecated
  publishedAt       DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  participations    FLParticipation[]

  @@unique([version, taskType])
  @@index([status, taskType])
  @@index([taskType, version])
}

model FLParticipation {
  id              String   @id @default(cuid())
  tenantId        String   @default("default")
  userId          String
  modelId         String
  round           Int
  localSampleSize Int      @default(0)
  localLoss       Float?
  epsilonSpent    Float?   // per-round DP budget for this client
  status          String   @default("completed") // completed, failed, timeout
  createdAt       DateTime @default(now())

  user            User     @relation("FLParticipationUser", fields: [userId], references: [id], onDelete: Cascade)
  model           FederatedModel @relation(fields: [modelId], references: [id], onDelete: Cascade)

  @@unique([userId, modelId, round])
  @@index([modelId, round])
  @@index([userId, createdAt])
}

enum AgentSessionStatusEnum {
  PLANNING
  RUNNING
  PAUSED
  AWAITING_REVIEW
  COMPLETED
  FAILED
}

enum AgentClassEnum {
  PERCEPTION
  DISCOVERY
  PROTOCOL
  SAFETY
  EXPLAINABILITY
}

model AgentSession {
  id              String                 @id @default(cuid())
  userId          String
  tenantId        String
  goal            String
  status          AgentSessionStatusEnum @default(PLANNING)
  plan            String?
  scratchpad      String?
  result          String?
  reviewItemIds   String?
  resumedAt       DateTime?
  reviewedBy      String?
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt
  completedAt     DateTime?

  user        User                   @relation("AgentSessionUser", fields: [userId], references: [id], onDelete: Cascade)
  tenant      Tenant                 @relation("AgentSessionTenant", fields: [tenantId], references: [id], onDelete: Cascade)
  steps       AgentStepLog[]

  @@index([userId])
  @@index([tenantId])
  @@index([status])
}

model AgentStepLog {
  id          String         @id @default(cuid())
  sessionId   String
  stepIndex   Int
  agentClass  AgentClassEnum
  input       String?
  output      String?
  status      String         @default("pending")
  durationMs  Int?
  error       String?
  createdAt   DateTime       @default(now())

  session     AgentSession   @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
}

// ─── Biological Drift Monitor ──────────────────────────────

enum DriftSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

model DriftSweep {
  id              String          @id @default(cuid())
  userId          String
  tenantId        String          @default("default")
  ranAt           DateTime        @default(now())
  biomarkersScanned Int           @default(0)
  driftsDetected  Int             @default(0)
  findings        String          @default("[]") // JSON array of DriftFinding
  triggerType     String          @default("scheduled") // scheduled | manual
  proactiveSessionId String?      // AgentSession spawned, if any
  createdAt       DateTime        @default(now())

  user            User            @relation("DriftSweepUser", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, ranAt])
  @@index([tenantId, ranAt])
}

model DriftNotification {
  id              String          @id @default(cuid())
  userId          String
  tenantId        String          @default("default")
  sweepId         String
  title           String
  body            String
  severity        DriftSeverity   @default(MEDIUM)
  biomarkerNames  String          @default("[]") // JSON array of names
  sessionId       String?         // linked proactive session
  readAt          DateTime?
  dismissedAt     DateTime?
  createdAt       DateTime        @default(now())

  user            User            @relation("DriftNotificationUser", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, readAt])
  @@index([userId, createdAt])
}

// ─── Clinical Safety & Governance ──────────────────────────

enum RiskCategory {
  GREEN
  YELLOW
  RED
}

model GovernancePolicy {
  id               String        @id @default(cuid())
  category         RiskCategory  @unique
  autoApprove      Boolean       @default(false)
  minAdherenceRate Float         @default(0.8)
  requireLabReview Boolean       @default(false)
  maxAutoApprovePerSession Int   @default(3)
  description      String?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
}

model GovernanceAuditLog {
  id              String        @id @default(cuid())
  sessionId       String
  userId          String
  tenantId        String        @default("default")
  compoundName    String
  riskCategory    RiskCategory
  decision        String        // AUTO_APPROVED, AWAITING_REVIEW, ESCALATED
  policySnapshot  String        // JSON snapshot of the policy at decision time
  adherenceRate   Float?
  reason          String
  createdAt       DateTime      @default(now())

  @@index([sessionId])
  @@index([userId, createdAt])
  @@index([decision, createdAt])
}

// ─── Clinical Signatures ───────────────────────────────────

model ClinicalSignature {
  id              String   @id @default(cuid())
  reviewItemId    String
  sessionId       String?
  clinicianId     String
  tenantId        String   @default("default")
  rationale       String
  compoundName    String?
  riskCategory    String?  // GREEN, YELLOW, RED at time of signing
  signatureHash   String   // SHA-256 of (clinicianId + reviewItemId + rationale + timestamp)
  signedAt        DateTime @default(now())
  clinicianName   String   // denormalized for PDF rendering
  clinicianEmail  String   // denormalized for PDF rendering
  createdAt       DateTime @default(now())

  @@unique([reviewItemId, clinicianId])
  @@index([sessionId])
  @@index([clinicianId, signedAt])
}