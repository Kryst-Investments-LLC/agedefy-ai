  @@index([sponsorId, status])
}

model MarketplaceMessageThread {
  id           String                 @id @default(cuid())
  tenantId     String                 @default("default")
  dealRoomId   String
  senderUserId String?
  senderRole   String
  messageType  MarketplaceMessageType @default(MESSAGE)
  body         String
  attachments  Json
  readAt       DateTime?
  createdAt    DateTime               @default(now())

  dealRoom   MarketplaceDealRoom @relation(fields: [dealRoomId], references: [id], onDelete: Cascade)
  senderUser User?               @relation("MarketplaceMessageSender", fields: [senderUserId], references: [id], onDelete: SetNull)

  @@index([dealRoomId, createdAt])
}

model MarketplaceTransaction {
  id                  String                       @id @default(cuid())
  tenantId            String                       @default("default")
  dealRoomId          String
  discoveryId         String
  sponsorId           String
  amountCents         Int
