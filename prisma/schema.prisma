  updatedAt           DateTime  @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  protocol Protocol? @relation(fields: [protocolId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([protocolId, createdAt])
}

// ÆonForge: Pharmaceutical Superintelligence Models
model AeonForgeCandidate {
  id              String   @id @default(cuid())
  tenantId        String   @default("default")
  userId          String
  prompt          String // User's discovery prompt
  rawResponse     Json // Full response from ÆonForge API
  candidates      Json // Array of discovered molecules / antigens / stacks
  simulationScore Float? // Overall simulation confidence [0, 1]
  healthspanDelta Int? // Predicted days/months/years improvement
  safetyScore     Float? // Safety assessment [0, 1]
  status          String   @default("pending") // pending | approved | rejected
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user                 User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  simulationResults    SimulationResult[]
  virtualTwinRuns      VirtualTwinRun[]
  experimentCandidates ExperimentCandidate[] @relation("ExperimentCandidateSource")

  @@index([userId, status])
  @@index([createdAt])
}

model SimulationResult {
  id                   String   @id @default(cuid())
  aeonForgeCandidateId String
  type                 String // virtual_cell | organ | whole_body | immunogenicity | senolytic_prediction
  result               Json // Structured simulation outcome
  confidence           Float // Confidence in simulation [0, 1]
  createdAt            DateTime @default(now())

  candidate AeonForgeCandidate @relation(fields: [aeonForgeCandidateId], references: [id], onDelete: Cascade)

  @@index([aeonForgeCandidateId, type])
}

model VirtualTwinRun {
  id                   String   @id @default(cuid())
  aeonForgeCandidateId String
  twinProfile          Json // age, biomarkers snapshot, genetics summary, health history
  predictedOutcomes    Json // Multi-hallmark response predictions
  createdAt            DateTime @default(now())

  candidate AeonForgeCandidate @relation(fields: [aeonForgeCandidateId], references: [id], onDelete: Cascade)

  @@index([aeonForgeCandidateId])
}

model CanonicalHealthEventRecord {
  id             String   @id @default(cuid())
  eventId        String
  tenantId       String
  subjectId      String
  type           String
  topic          String
  aggregateId    String
  aggregateType  String
  occurredAt     DateTime
  recordedAt     DateTime
  emittedAt      DateTime
  storedAt       DateTime @default(now())
  partitionKey   String
  sequence       Int?
  idempotencyKey String?
  envelope       Json
  event          Json

  @@unique([tenantId, eventId])
  @@unique([tenantId, idempotencyKey])
  @@index([tenantId, subjectId, occurredAt])
  @@index([tenantId, aggregateId, occurredAt])
  @@index([tenantId, type, occurredAt])
  @@index([tenantId, topic, occurredAt])
}

model CanonicalHealthEventOutboxRecord {
  id            String    @id @default(cuid())
  eventRecordId String    @unique
  tenantId      String
  topic         String
  partitionKey  String
  message       Json
  headers       Json?
  status        String    @default("pending")
  attemptCount  Int       @default(0)
  availableAt   DateTime  @default(now())
  publishedAt   DateTime?
  lastError     String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([tenantId, status, availableAt])
  @@index([topic, status, availableAt])
}

model OrchestrationJob {
  id              String                 @id @default(cuid())
  tenantId        String
  organizationId  String?
  queue           OrchestrationJobQueue
  jobType         String
  dedupeKey       String?
  status          OrchestrationJobStatus @default(QUEUED)
  priority        Int                    @default(100)
  payload         Json
  result          Json?
  lastError       String?
  attempts        Int                    @default(0)
  maxAttempts     Int                    @default(5)
  availableAt     DateTime               @default(now())
  leasedAt        DateTime?
  leaseExpiresAt  DateTime?
  completedAt     DateTime?
  canceledAt      DateTime?
  retainedUntil   DateTime?
  createdByUserId String?
  parentJobId     String?
  correlationId   String?
  requestId       String?
  traceContext    Json?
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt
  createdBy       User?                  @relation("OrchestrationJobCreator", fields: [createdByUserId], references: [id], onDelete: SetNull)
  parent          OrchestrationJob?      @relation("OrchestrationJobParent", fields: [parentJobId], references: [id], onDelete: SetNull)
  children        OrchestrationJob[]     @relation("OrchestrationJobParent")

  @@unique([tenantId, dedupeKey])
  @@index([tenantId, queue, status, availableAt, priority])
  @@index([tenantId, jobType, status, availableAt])
  @@index([tenantId, retainedUntil])
  @@index([parentJobId])
}

