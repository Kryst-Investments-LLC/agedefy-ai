  metadataFit          Float    @default(0)
  rationale            String
  rank                 Int?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  discovery MarketplaceDiscovery @relation(fields: [discoveryId], references: [id], onDelete: Cascade)
  scientist MarketplaceScientist @relation(fields: [scientistId], references: [id], onDelete: Cascade)
  sponsor   MarketplaceSponsor   @relation(fields: [sponsorId], references: [id], onDelete: Cascade)

