// ════════════════════════════════════════════════════════════════════════
// TRANSLATIONAL RESEARCH FOUNDATION (multi-omics, causal, twin, N-of-1,
// cancer, pharmacogenomics, knowledge-graph edges, agent provenance,
// CRO bridge, GxP signature manifest).
//
// These models intentionally use first-class enums and explicit numeric
// fields with units, batch IDs, and limits-of-detection so that the
// discovery / safety / explainability agents can cite them as evidence
// without parsing free-text.
// ════════════════════════════════════════════════════════════════════════

// ── Multi-omics ───────────────────────────────────────────────────────

enum OmicsAssayKind {
  METHYLATION_EPIC // Illumina EPIC v1/v2 — Horvath/GrimAge/PhenoAge
  PROTEOMICS_SOMASCAN
  PROTEOMICS_OLINK
  METABOLOMICS_NIGHTINGALE
  METABOLOMICS_METABOLON
  TRANSCRIPTOMICS_BULK
  TRANSCRIPTOMICS_SINGLECELL
  IMMUNE_REPERTOIRE_TCR
  IMMUNE_REPERTOIRE_BCR
  MICROBIOME_16S
  MICROBIOME_SHOTGUN
  CTDNA_LIQUID_BIOPSY
  GENOME_WGS
  GENOME_WES
  PHARMACOGENOMICS_PANEL
}

enum OmicsUnitVocab {
  // SI / common — controlled vocabulary so agents don't have to parse strings.
  NG_PER_ML
  PG_PER_ML
  UG_PER_ML
  MMOL_PER_L
  UMOL_PER_L
  NMOL_PER_L
  COUNT_PER_UL
  PCT
  RATIO
  Z_SCORE
  BETA_VALUE // methylation β
  M_VALUE // methylation M
  TPM // transcripts per million
  CPM // counts per million
  RPM // reads per million
  COPIES_PER_ML // ctDNA, viral load
  MAF // mutant allele fraction (0..1)
  MTB_PER_MB // tumor mutational burden
  ARBITRARY // last-resort, must include unitFreeText
}

model OmicsAssayBatch {
  id              String         @id @default(cuid())
  tenantId        String         @default("default")
  kind            OmicsAssayKind
  vendor          String // "Illumina", "SomaLogic", "Nightingale Health"
  assayVersion    String // e.g. "EPICv2", "SomaScan 7k", "Olink Explore 3072"
  pipelineVersion String // bioinformatics pipeline version (e.g. "minfi 1.50.0")
  reagentLot      String?
  runDate         DateTime
  qcPassed        Boolean        @default(false)
  qcReportUri     String?
  notes           String?
  createdAt       DateTime       @default(now())
  samples         OmicsSample[]

  @@index([tenantId, kind, runDate])
}

model OmicsSample {
  id           String             @id @default(cuid())
  tenantId     String             @default("default")
  userId       String
  batchId      String
  sampleType   String // "whole_blood","serum","plasma","saliva","stool","tumor_biopsy"
  collectedAt  DateTime
  receivedAt   DateTime?
  externalId   String? // accession at the lab
  qcPassed     Boolean            @default(false)
  qcMetrics    Json? // JSON blob: yield, RIN, contamination, etc.
  createdAt    DateTime           @default(now())
  user         User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  batch        OmicsAssayBatch    @relation(fields: [batchId], references: [id], onDelete: Cascade)
  measurements OmicsMeasurement[]

  @@index([userId, collectedAt])
  @@index([tenantId, sampleType])
}

model OmicsMeasurement {
  id               String         @id @default(cuid())
  tenantId         String         @default("default")
  sampleId         String
  // Analyte addressing — at least one of (analyteCode, geneSymbol, cpgSite, taxonId, mutationHgvs).
  analyteCode      String? // HGNC/UniProt/HMDB/LOINC
  geneSymbol       String?
  cpgSite          String? // cgXXXXXXXX for methylation
  taxonId          Int? // NCBI taxonomy id for microbiome
  mutationHgvs     String? // for ctDNA / WES
  value            Float
  unit             OmicsUnitVocab
  unitFreeText     String? // only set when unit=ARBITRARY
  limitOfDetection Float?
  limitOfQuant     Float?
  isBelowLOD       Boolean        @default(false)
  qcFlag           String? // "ok","low_signal","contamination", etc.
  measuredAt       DateTime       @default(now())
  sample           OmicsSample    @relation(fields: [sampleId], references: [id], onDelete: Cascade)

  @@index([sampleId])
  @@index([tenantId, analyteCode])
  @@index([tenantId, geneSymbol])
  @@index([tenantId, cpgSite])
}

// ── Causal layer ──────────────────────────────────────────────────────

model PolygenicScore {
  id           String   @id @default(cuid())
  tenantId     String   @default("default")
  userId       String
  trait        String // e.g. "CAD","T2D","longevity","breast_cancer"
  pgsCatalogId String? // PGSxxxxxx id when available
  score        Float
  percentile   Float?
  ancestry     String? // EUR/AFR/EAS/SAS/AMR/MIX
  modelVersion String
  computedAt   DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, trait])
}

model MendelianRandomizationFinding {
  id         String   @id @default(cuid())
  tenantId   String   @default("default")
  userId     String?
  exposure   String // e.g. "LDL-C","CRP","IL-6"
  outcome    String // e.g. "CAD","all-cause mortality"
  betaIvw    Float // inverse-variance-weighted causal estimate
  seIvw      Float
  pIvw       Float
  nSnps      Int
  egger      Float? // MR-Egger intercept (pleiotropy check)
  source     String // "openGWAS","local","ieu-mr-base"
  computedAt DateTime @default(now())
  user       User?    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([exposure, outcome])
  @@index([userId])
}

// ── Digital twin (PBPK + systems-biology) ─────────────────────────────

model PhysiologicalTwin {
  id             String              @id @default(cuid())
  tenantId       String              @default("default")
  userId         String              @unique
  weightKg       Float?
  heightCm       Float?
  sexAtBirth     String? // "male","female","intersex"
  age            Int?
  ancestry       String?
  egfrMlMin      Float? // renal function for PBPK
  childPughClass String? // "A","B","C" for hepatic
  parameterJson  Json // PBPK compartment params (volumes, clearances)
  hallmarkJson   Json // hallmark-of-aging × hallmark-of-cancer state vector
  modelVersion   String
  updatedAt      DateTime            @updatedAt
  user           User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  simulations    TwinSimulationRun[]

  @@index([tenantId])
}

model TwinSimulationRun {
  id                    String            @id @default(cuid())
  tenantId              String            @default("default")
  twinId                String
  userId                String
  intervention          String // free text label, links to compound/protocol when known
  compoundId            String?
  doseMg                Float?
  scheduleCron          String?
  horizonDays           Int
  endpoint              String // e.g. "GrimAge_delta","CRP_AUC"
  predictedMean         Float
  predictedSdLo         Float // 95% CI lower
  predictedSdHi         Float // 95% CI upper
  uncertaintyKind       String // "monte_carlo","bootstrap","conformal"
  inputsHash            String // sha256 of inputs — required for reproducible replay
  modelVersion          String
  // ── Tier 5.3: Extended prediction logging ──
  /// How many days ahead this prediction applies
  predictionWindowDays  Int               @default(0)
  /// When the prediction window closes — scored after this date (createdAt + predictionWindowDays)
  predictionExpiresAt   DateTime?
  /// Full input assumptions: { compoundIds, doses, baselineBiomarkers, pkParamsUsed, modelVersion }
  pkParamsUsedJson      Json?
  /// Full output trajectories: { biomarker, predictedValues: [{ t, value }] }[]
  outcomeTrajectoryJson Json?
  /// Accuracy score filled in by twin-scorer.ts after predictionExpiresAt
  twinAccuracyScore     Float?
  createdAt             DateTime          @default(now())
  twin                  PhysiologicalTwin @relation(fields: [twinId], references: [id], onDelete: Cascade)

  @@index([userId, endpoint, createdAt])
  @@index([inputsHash])
  @@index([predictionExpiresAt, twinAccuracyScore])
}

// ── N-of-1 / adaptive trial engine ────────────────────────────────────

enum NofOneDesign {
  AB_CROSSOVER
  ABA_CROSSOVER
  ABAB_CROSSOVER
  N_OF_1_RCT_BLINDED
  WASHOUT_RECHALLENGE
}

enum NofOneStatus {
  DESIGN
  ACTIVE
  PAUSED
  STOPPED_FOR_BENEFIT
  STOPPED_FOR_FUTILITY
  STOPPED_FOR_HARM
  COMPLETED
}

model NofOneTrial {
  id                 String         @id @default(cuid())
  tenantId           String         @default("default")
  userId             String
  hypothesis         String
  design             NofOneDesign
  primaryEndpoint    String // analyte code or biomarker name
  secondaryEndpoints Json // JSON list
  preregisteredHash  String // sha256 of pre-registration JSON (frozen at start)
  preregisteredJson  Json // full pre-registration document
  status             NofOneStatus   @default(DESIGN)
  bayesianStopJson   Json // {priorMu, priorSd, deltaThreshold, futilityCutoff}
  irbApprovalRef     String?
  startedAt          DateTime?
  stoppedAt          DateTime?
  stopReason         String?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  user               User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  arms               NofOneArm[]
  periods            NofOnePeriod[]

  @@index([userId, status])
  @@index([tenantId, status])
}

model NofOneArm {
  id           String      @id @default(cuid())
  trialId      String
  label        String // "A: rapamycin 6mg weekly" / "B: placebo"
  compoundId   String?
  doseMg       Float?
  scheduleCron String?
  trial        NofOneTrial @relation(fields: [trialId], references: [id], onDelete: Cascade)

  @@index([trialId])
}

model NofOnePeriod {
  id           String      @id @default(cuid())
  trialId      String
  armLabel     String
  orderIndex   Int
  startDate    DateTime
  endDate      DateTime
  observations Json // JSON: [{measuredAt, analyte, value, unit}]
  trial        NofOneTrial @relation(fields: [trialId], references: [id], onDelete: Cascade)

  @@index([trialId, orderIndex])
}

// ── Pharmacogenomics ──────────────────────────────────────────────────

enum PgxMetabolizerPhenotype {
  POOR
  INTERMEDIATE
  NORMAL
  RAPID
  ULTRARAPID
  INDETERMINATE
}

model PharmacogenomicProfile {
  id           String    @id @default(cuid())
  tenantId     String    @default("default")
  userId       String    @unique
  // Each gene + diplotype + assigned phenotype (CPIC convention).
  variantsJson Json // [{gene:"CYP2D6", diplotype:"*1/*4", phenotype:"INTERMEDIATE", activityScore:1.0}]
  panelVendor  String?
  panelVersion String?
  reportedAt   DateTime?
  createdAt    DateTime  @default(now())
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

model DrugDrugInteraction {
  id            String   @id @default(cuid())
  drugA         String // RxNorm or compound id
  drugB         String
  mechanism     String // "CYP3A4 inhibition","P-gp substrate","QTc additive"
  severity      String // "minor","moderate","major","contraindicated"
  evidenceGrade String // "A","B","C","D" (CPIC-style)
  source        String // "DrugBank","PharmGKB","CPIC","Lexicomp"
  notes         String?
  updatedAt     DateTime @updatedAt

  @@unique([drugA, drugB, mechanism])
  @@index([drugA])
  @@index([drugB])
}

// ── Knowledge graph: typed edges with provenance ──────────────────────

enum KgEdgeType {
  INHIBITS
  ACTIVATES
  UPREGULATES
  DOWNREGULATES
  BINDS
  SYNTHETIC_LETHAL_WITH
  CAUSES_RESISTANCE_TO
  CO_EXPRESSED_WITH
  GENE_DISEASE_ASSOCIATION
  DRUG_TARGET
  DRUG_INDICATION
  DRUG_CONTRAINDICATION
  PATHWAY_MEMBER
  POPULATION_ASSOCIATION // observational RWE edge from the flywheel — association, NOT mechanism
}

enum KgEvidenceGrade {
  A_HIGH
  B_MODERATE
  C_LOW
  D_VERY_LOW
}

model KgNode {
  id         String   @id @default(cuid())
  tenantId   String   @default("default")
  kind       String // "gene","protein","compound","pathway","disease","cell_type"
  externalId String // HGNC, UniProt, ChEMBL, MONDO, etc.
  label      String
  synonyms   Json? // JSON array
  attributes Json? // JSON
  createdAt  DateTime @default(now())
  outgoing   KgEdge[] @relation("EdgeFrom")
  incoming   KgEdge[] @relation("EdgeTo")

  @@unique([tenantId, kind, externalId])
  @@index([tenantId, kind])
}

model KgEdge {
  id             String          @id @default(cuid())
  tenantId       String          @default("default")
  fromNodeId     String
  toNodeId       String
  edgeType       KgEdgeType
  evidenceGrade  KgEvidenceGrade
  source         String // "OpenTargets","ChEMBL","DepMap","PubMed:PMID"
  pubmedIds      Json? // JSON array of PMIDs
  effectSize     Float?
  effectSizeUnit String?
  confidence     Float? // 0..1
  attributes     Json? // JSON
  createdAt      DateTime        @default(now())
  fromNode       KgNode          @relation("EdgeFrom", fields: [fromNodeId], references: [id], onDelete: Cascade)
  toNode         KgNode          @relation("EdgeTo", fields: [toNodeId], references: [id], onDelete: Cascade)

  @@index([fromNodeId, edgeType])
  @@index([toNodeId, edgeType])
  @@index([tenantId, edgeType, evidenceGrade])
}

// ── Cancer module ─────────────────────────────────────────────────────

model TumorProfile {
  id                String             @id @default(cuid())
  tenantId          String             @default("default")
  userId            String
  primarySite       String
  histology         String?
  stageAjcc         String?
  diagnosedAt       DateTime
  tmbPerMb          Float? // tumor mutational burden
  msiStatus         String? // "MSS","MSI-L","MSI-H"
  hrdScore          Float? // homologous recombination deficiency
  pdL1Cps           Float?
  driverMutations   Json // JSON: [{gene, hgvs, vaf, depth}]
  neoantigensJson   Json? // [{peptide, hla, affinity_nM}]
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  user              User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  ctdnaPoints       CtdnaTimepoint[]
  recistAssessments RecistAssessment[]

  @@index([userId, diagnosedAt])
}

model CtdnaTimepoint {
  id             String       @id @default(cuid())
  tumorProfileId String
  measuredAt     DateTime
  vafMax         Float? // max mutant allele fraction across panel
  copiesPerMl    Float?
  mrdStatus      String // "POSITIVE","NEGATIVE","INDETERMINATE"
  panelVendor    String?
  panelVersion   String?
  tumorProfile   TumorProfile @relation(fields: [tumorProfileId], references: [id], onDelete: Cascade)

  @@index([tumorProfileId, measuredAt])
}

model RecistAssessment {
  id                   String       @id @default(cuid())
  tumorProfileId       String
  assessedAt           DateTime
  scheme               String // "RECIST_1_1","iRECIST"
  response             String // "CR","PR","SD","PD","iCPD","iUPD"
  sumLongestDiameterMm Float?
  notes                String?
  tumorProfile         TumorProfile @relation(fields: [tumorProfileId], references: [id], onDelete: Cascade)

  @@index([tumorProfileId, assessedAt])
}

model TranscriptomicSignature {
  id                   String                 @id @default(cuid())
  tenantId             String                 @default("default")
  userId               String? // null => published reference signature
  name                 String
  sourceAssay          String // bulk RNA-seq, microarray
  upGenes              Json // JSON array of HGNC symbols
  downGenes            Json // JSON array
  createdAt            DateTime               @default(now())
  user                 User?                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  DrugRepurposingScore DrugRepurposingScore[]

  @@index([userId])
}

model DrugRepurposingScore {
  id          String                  @id @default(cuid())
  tenantId    String                  @default("default")
  signatureId String
  compoundId  String
  cmapScore   Float // -1..+1, negative = candidate (anti-correlated)
  source      String // "L1000","CMap","local"
  computedAt  DateTime                @default(now())
  signature   TranscriptomicSignature @relation(fields: [signatureId], references: [id], onDelete: Cascade)

  @@index([signatureId, cmapScore])
  @@index([compoundId])
}

// ── Agent provenance: every claim must cite ───────────────────────────

enum AgentClaimEvidenceKind {
  MECHANISTIC_SIMULATION // TwinSimulationRun.id
  KG_EDGE // KgEdge.id
  COHORT_STATISTIC // FederatedAggregateInsight or local cohort id
  N_OF_1_RESULT // NofOneTrial.id
  REGULATORY_LABEL // FDA/EMA label section
}

model AgentClaim {
  id           String                 @id @default(cuid())
  tenantId     String                 @default("default")
  sessionId    String // AgentSession.id
  agentClass   String // "discovery","protocol","safety","explainability"
  claimText    String
  evidenceKind AgentClaimEvidenceKind
  evidenceRef  String // foreign id or URI
  confidence   Float // 0..1
  createdAt    DateTime               @default(now())

  @@index([sessionId])
  @@index([tenantId, agentClass, createdAt])
}

// Durable agent reasoning trace. The in-memory emitter (lib/agents/trace-emitter)
// is ephemeral (30-min TTL); this table persists the reasoning tree — inputs,
// decisions, and structured `evidence` (citations / confidence) — for audit and
// deterministic replay. `id` is the emitter's event id so re-persisting a
// resumed session is idempotent (createMany skipDuplicates).
model AgentTraceEvent {
  id         String   @id // TraceEvent.id (uuid from the emitter)
  sessionId  String // AgentSession.id
  tenantId   String   @default("default")
  kind       String // TraceEventKind
  agentClass String?
  icon       String
  message    String
  detail     String?
  evidence   Json? // structured TraceEvidence (citations, inputs, model, confidence)
  emittedAt  DateTime // TraceEvent.timestamp
  createdAt  DateTime @default(now())

  @@index([sessionId])
  @@index([tenantId, kind, createdAt])
}

// ── Wet-lab / CRO bridge ──────────────────────────────────────────────

model CdiscOdmExport {
  id          String   @id @default(cuid())
  tenantId    String   @default("default")
  trialId     String? // NofOneTrial.id
  studyOid    String
  documentXml String // CDISC ODM-XML
  generatedAt DateTime @default(now())

  @@index([tenantId, studyOid])
}

enum LabResultRecStatus {
  RECEIVED
  PARSED
  RECONCILED
  FLAGGED
  REJECTED
}

model LabResultReconciliation {
  id              String             @id @default(cuid())
  tenantId        String             @default("default")
  externalOrderId String
  vendor          String
  receivedAt      DateTime           @default(now())
  rawPayload      String
  parsedJson      Json?
  status          LabResultRecStatus @default(RECEIVED)
  matchedSampleId String? // OmicsSample.id once reconciled
  notes           String?

  @@index([tenantId, status])
  @@index([externalOrderId])
}

// ── Compliance: signed prompts, replay determinism, jurisdiction gate ─

model AgentPromptVersion {
  id          String    @id @default(cuid())
  agentClass  String
  version     String
  promptText  String
  contentHash String    @unique // sha256(promptText)
  signature   String? // detached signature (Ed25519) of contentHash
  signedBy    String?
  signedAt    DateTime?
  active      Boolean   @default(false)
  createdAt   DateTime  @default(now())

  @@index([agentClass, active])
}

model AgentSessionReplayManifest {
  id             String   @id @default(cuid())
  sessionId      String   @unique
  scratchpadHash String // sha256 of canonicalized scratchpad
  modelIds       Json // JSON: {discovery:"gpt-x@v1", safety:"claude-y@v2"}
  promptHashes   Json // JSON: {discovery:"abc...", ...}
  inputsHash     String
  determinismOk  Boolean  @default(false)
  createdAt      DateTime @default(now())

  @@index([scratchpadHash])
}

model JurisdictionGateDecision {
  id             String   @id @default(cuid())
  tenantId       String   @default("default")
  sessionId      String
  jurisdiction   String // ISO-3166 alpha-2 + optional region (e.g. "US-CA")
  ruleSetVersion String // hash/version of the rules pack from .github-private/legal-rules
  decision       String // "ALLOW","REDACT","BLOCK"
  reason         String
  createdAt      DateTime @default(now())

  @@index([sessionId])
  @@index([tenantId, jurisdiction, decision])
}

// ── Open evaluation suite ─────────────────────────────────────────────

model EvalBenchRun {
  id           String   @id @default(cuid())
  benchName    String // "drift_detection_v1","mech_calibration_v2","safety_panel_v1"
  benchVersion String
  datasetHash  String
  metricsJson  Json // {precision, recall, brier, ece, ...}
  agentClass   String?
  modelVersion String?
  ranAt        DateTime @default(now())

  @@index([benchName, ranAt])
}

// ─── Experiment / Candidate Lifecycle Tracking ──────────────

enum ExperimentCandidateStatus {
  PROPOSED
  SCREENED
  SENT_TO_LAB
  RESULT_LOGGED
  FED_BACK
}

enum ExperimentCandidateKind {
  CHEMBL
  AI
}

model ExperimentCandidate {
  id       String                    @id @default(cuid())
  tenantId String                    @default("default")
  userId   String
  kind     ExperimentCandidateKind
  status   ExperimentCandidateStatus @default(PROPOSED)

  // ── Identity ───────────────────────────────────────────────
  displayName String
  smiles      String?

  // ── ChEMBL provenance ──────────────────────────────────────
  chemblId    String?
  chemblScore Float?
  chemblJson  Json? // LibrarySearchHit snapshot at time of add

  // ── AI provenance ──────────────────────────────────────────
  aeonForgeCandidateId String? // FK to AeonForgeCandidate (optional)
  aiMolJson            Json? // AeonForgeCandidateMolecule snapshot at time of add

  // ── Sidecar snapshots (populated at SCREENED) ──────────────
  screenJson Json? // ScreenResult
  dockJson   Json? // DockResult

  // ── Researcher context ─────────────────────────────────────
  targetName     String?
  targetChemblId String?
  hypothesisNote String?
  notes          String?

  // ── Active-learning scores (populated at FED_BACK) ─────────
  feedbackScore    Float? // 0–1: aggregate goodness from lab results
  uncertaintyScore Float? // 0–1: confidence in feedbackScore
  acquisitionScore Float? // 0–1: priority for next experimental round

  // ── FEP triage gate (populated by POST /fep-triage) ────────
  fepGateScore  Float? // 0–1: composite worthiness of an FEP run
  fepGateReason String? // human-readable triage rationale
  fepJson       Json? // FepResult snapshot (populated after a real FEP run)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user               User                       @relation("ExperimentCandidateUser", fields: [userId], references: [id], onDelete: Cascade)
  aeonForgeCandidate AeonForgeCandidate?        @relation("ExperimentCandidateSource", fields: [aeonForgeCandidateId], references: [id], onDelete: SetNull)
  events             ExperimentCandidateEvent[]
  labResults         CandidateLabResult[]
  labSubmissions     LabSubmission[]            @relation("LabSubmissionCandidate")
  feedbackRuns       CandidateFeedbackRun[]     @relation("FeedbackRunCandidate")

  @@index([userId, status])
  @@index([userId, createdAt])
  @@index([chemblId])
  @@index([tenantId, status])
}

model ExperimentCandidateEvent {
  id          String                     @id @default(cuid())
  candidateId String
  actorUserId String
  fromStatus  ExperimentCandidateStatus?
  toStatus    ExperimentCandidateStatus
  notes       String?
  metadata    Json? // stage-specific bag: {lab, cro} at SENT_TO_LAB, etc.
  createdAt   DateTime                   @default(now())

  candidate ExperimentCandidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  actorUser User                @relation("ExperimentCandidateEventActor", fields: [actorUserId], references: [id], onDelete: Cascade)

  @@index([candidateId, createdAt])
  @@index([actorUserId])
}

model CandidateLabResult {
  id           String   @id @default(cuid())
  candidateId  String
  submissionId String? // set when the result arrived via a LabSubmission ingest
  assayName    String // "IC50_SIRT1", "cell_viability_%", "GI50"
  value        Float
  unit         String // "µM", "%", "nM"
  operator     String   @default("=") // "=", "<", ">" — for limit-of-detection values
  flag         String? // "active" | "inactive" | "borderline" | "toxic"
  assayType    String? // "biochemical" | "cellular" | "animal" | "in_silico"
  lab          String?
  measuredAt   DateTime
  rawDataUri   String? // link to ELN / raw file
  notes        String?
  createdAt    DateTime @default(now())

  candidate  ExperimentCandidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  submission LabSubmission?      @relation("LabSubmissionResults", fields: [submissionId], references: [id], onDelete: SetNull)

  @@index([candidateId, assayName])
  @@index([candidateId, measuredAt])
  @@index([submissionId])
}

// ─── Lab handoff & result ingest ───────────────────────────────────────────────
// A LabSubmission snapshots a candidate at the moment it leaves the platform
// for physical lab work. The lab returns results via a token-authenticated
// ingest endpoint; results are linked back to ExperimentCandidate.

enum LabSubmissionStatus {
  PENDING // awaiting results
  PARTIAL // some results received
  COMPLETE // researcher or lab marked done
  VOID // cancelled
}

model LabSubmission {
  id              String              @id @default(cuid())
  candidateId     String
  userId          String
  labName         String
  labContact      String? // email or contact name
  // SHA-256 of the one-time submission token.
  // The plaintext token is returned once at creation and never stored.
  tokenHash       String              @unique
  status          LabSubmissionStatus @default(PENDING)
  // Immutable snapshot of the candidate package at export time (no token).
  packageJson     Json
  // Researcher-specified assay requests, stored as an array of objects.
  requestedAssays Json
  deadlineAt      DateTime?
  notes           String?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  candidate  ExperimentCandidate  @relation("LabSubmissionCandidate", fields: [candidateId], references: [id], onDelete: Cascade)
  user       User                 @relation("LabSubmissionUser", fields: [userId], references: [id], onDelete: Cascade)
  labResults CandidateLabResult[] @relation("LabSubmissionResults")

  @@index([candidateId])
  @@index([userId, status])
}

// ─── CRO orchestration ─────────────────────────────────────────────────────────
// A CroWorkOrder is the commercial/escrow layer that routes a FEP-triaged
// candidate to a partner CRO for physical validation. Lifecycle:
//   DRAFT → QUOTED → FUNDED → IN_PROGRESS → DELIVERED → RECONCILED  (or CANCELLED)
// Milestone release is gated on reconciled CandidateLabResult rows; the work
// order references its candidate/sponsor by id (scalar) and links to the
// LabSubmission used to physically dispatch the package.

enum CroWorkOrderStatus {
  DRAFT // created from a triaged candidate; not yet quoted
  QUOTED // CRO returned a price/quote
  FUNDED // sponsor funded escrow
  IN_PROGRESS // lab work underway
  DELIVERED // results delivered; awaiting reconciliation
  RECONCILED // results reconciled into CandidateLabResult; loop closed
  CANCELLED // terminated before completion
}

model CroPartner {
  id             String         @id @default(cuid())
  tenantId       String         @default("default")
  name           String
  capabilities   Json // ["biochemical","cellular","animal", assay codes…]
  turnaroundDays Int?
  pricingJson    Json? // tiered pricing reference
  contactEmail   String?
  status         String         @default("active") // active | paused | offboarded
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  workOrders     CroWorkOrder[]

  @@index([tenantId, status])
}

model CroWorkOrder {
  id                  String             @id @default(cuid())
  tenantId            String             @default("default")
  candidateId         String // ExperimentCandidate id (scalar — no back-relation)
  userId              String // sponsoring researcher id (scalar)
  croPartnerId        String
  assayType           String // "biochemical" | "cellular" | "animal"
  requestedAssays     Json // array of assay request objects
  milestonePlan       Json // [{name, amountCents, status}]
  quoteCents          Int?
  currency            String             @default("USD")
  escrowTransactionId String? // MarketplaceTransaction escrow id, once funded
  submissionId        String? // LabSubmission id, once dispatched
  fepGateScoreAtOrder Float? // triage score that justified the order (provenance)
  status              CroWorkOrderStatus @default(DRAFT)
  notes               String?
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt

  croPartner   CroPartner          @relation(fields: [croPartnerId], references: [id], onDelete: Restrict)
  statusEvents CroWorkOrderEvent[]

  @@index([tenantId, status])
  @@index([candidateId])
  @@index([croPartnerId, status])
  @@index([userId, status])
}

model CroWorkOrderEvent {
  id          String              @id @default(cuid())
  workOrderId String
  fromStatus  CroWorkOrderStatus?
  toStatus    CroWorkOrderStatus
  actorUserId String?
  note        String?
  createdAt   DateTime            @default(now())

  workOrder CroWorkOrder @relation(fields: [workOrderId], references: [id], onDelete: Cascade)

  @@index([workOrderId, createdAt])
}

// ─── Active-learning feedback runs ────────────────────────────────────────────
model CandidateFeedbackRun {
  id               String   @id @default(cuid())
  candidateId      String
  userId           String
  feedbackScore    Float
  uncertaintyScore Float
  activityScore    Float
  selectivityScore Float
  toxicityScore    Float
  nResults         Int
  rationale        String
  createdAt        DateTime @default(now())

  candidate ExperimentCandidate @relation("FeedbackRunCandidate", fields: [candidateId], references: [id], onDelete: Cascade)
  user      User                @relation("FeedbackRunUser", fields: [userId], references: [id], onDelete: Cascade)

  @@index([candidateId])
  @@index([userId])
}

// ─── Pilot metrics snapshots ──────────────────────────────────────────────────
model PilotMetricsSnapshot {
  id         String   @id @default(cuid())
  userId     String
  windowDays Int      @default(90)
  computedAt DateTime @default(now())

  // hit-rate uplift
  alHitRate       Float
  baselineHitRate Float
  hitRateUplift   Float
  alN             Int
  baselineN       Int

  // cost
  totalSpendCents Int
  validatedHits   Int
  costPerHitCents Int?

  // cycle time (seconds)
  medianCycleTimeSec Float?
  p75CycleTimeSec    Float?
  stageTimes         Json // { proposedToScreened, screenedToSent, sentToLogged, loggedToFed } median secs

  // classification accuracy
  screenPositives   Int
  screenNegatives   Int
  falsePositiveRate Float?
  falseNegativeRate Float?

  user User @relation("PilotMetricsSnapshotUser", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, computedAt])
}

// ─── External screening adapters ───────────────────────────────────────────────
// Expert users can register their own ADMET/screening HTTP endpoints and route
// candidates through them instead of (or alongside) the built-in sidecar.

model ExternalScreeningAdapter {
  id          String   @id @default(cuid())
  userId      String
  tenantId    String   @default("default")
  name        String
  endpointUrl String
  authHeader  String   @default("Authorization")
  authScheme  String   @default("Bearer")
  // Token sent to the external endpoint in the auth header.
  // TODO: encrypt with SCREENING_ADAPTER_ENC_KEY before storing in production.
  secret      String
  timeoutMs   Int      @default(15000)
  enabled     Boolean  @default(true)
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User                   @relation("ExternalScreeningAdapterUser", fields: [userId], references: [id], onDelete: Cascade)
  runs ExternalScreeningRun[]

  @@index([userId])
  @@index([tenantId])
}

model ExternalScreeningRun {
  id           String   @id @default(cuid())
  adapterId    String
  candidateId  String?
  smiles       String
  durationMs   Int?
  statusCode   Int?
  success      Boolean
  rawResponse  Json?
  normalized   Json?
  errorMessage String?
  createdAt    DateTime @default(now())

  adapter ExternalScreeningAdapter @relation(fields: [adapterId], references: [id], onDelete: Cascade)

  @@index([adapterId, createdAt])
  @@index([candidateId])
}

// ─── Self-Improving Loop Architecture ──────────────────────

enum LoopCycleStatus {
  OBSERVE
  PLAN
  ACT
  REFLECT
  COMPLETE
  FAILED
}

enum LoopTriggerReason {
  BIOMARKER_INGEST
  LAB_RESULT
  WEARABLE_SYNC
  PROTOCOL_CHANGE
  SCHEDULED
  MANUAL
}

/// Persisted state for one full OBSERVE→PLAN→ACT→REFLECT cycle.
/// Created by loop-trigger.ts whenever a new physiological signal arrives.
model LoopCycle {
  id             String            @id @default(cuid())
  userId         String
  tenantId       String            @default("default")
  status         LoopCycleStatus   @default(OBSERVE)
  triggeredBy    LoopTriggerReason
  snapshotId     String?
  agentSessionId String?
  startedAt      DateTime          @default(now())
  completedAt    DateTime?
  failedReason   String?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  user             User                   @relation("LoopCycleUser", fields: [userId], references: [id], onDelete: Cascade)
  snapshot         PhysiologicalSnapshot? @relation("LoopCycleSnapshot", fields: [snapshotId], references: [id], onDelete: SetNull)
  protocolOutcome  ProtocolOutcome?       @relation("LoopCycleOutcome")
  reflectionReport ReflectionReport?      @relation("LoopCycleReflection")

  @@index([userId, status, createdAt])
  @@index([tenantId, status, createdAt])
}

/// Fused physiological state snapshot — the shared context all loop stages consume.
/// Materialized from biomarkers, active protocol, digital twin, and risk signals.
model PhysiologicalSnapshot {
  id                     String    @id @default(cuid())
  userId                 String
  tenantId               String    @default("default")
  materializedAt         DateTime  @default(now())
  /// Latest value per biomarker name: { [name]: { value, unit, trend, lastUpdated } }
  biomarkersJson         Json      @default("{}")
  /// Aggregate risk dimensions: { overall, cardiovascular, metabolic, inflammation }
  riskScoresJson         Json      @default("{}")
  activeProtocolId       String?
  protocolAdherence      Float?
  protocolWeeksActive    Float?
  /// Ordered list of dysregulated pathway names, most severe first
  dysregulatedPathways   Json      @default("[]")
  twinLastSimAt          DateTime?
  twinPredictionAccuracy Float?
  /// LoopCycle IDs awaiting reflection
  pendingReflections     Json      @default("[]")
  createdAt              DateTime  @default(now())

  user       User        @relation("PhysiologicalSnapshotUser", fields: [userId], references: [id], onDelete: Cascade)
  loopCycles LoopCycle[] @relation("LoopCycleSnapshot")

  @@index([userId, materializedAt])
  @@index([tenantId, materializedAt])
}

// ─── Tier 2: REFLECT Loop ──────────────────────────────────

/// Per-cycle record comparing predicted vs observed biomarker movements.
/// Written at the end of each loop cycle before reflection runs.
model ProtocolOutcome {
  id                     String    @id @default(cuid())
  userId                 String
  tenantId               String    @default("default")
  loopCycleId            String    @unique
  protocolId             String?
  cycleStartDate         DateTime
  cycleEndDate           DateTime?
  /// JSON: { name, predictedDelta, predictedDirection }[]
  targetBiomarkers       Json      @default("[]")
  /// JSON: { name, observedDelta, observedDirection, confidence }[]
  observedBiomarkers     Json      @default("[]")
  twinSimulationId       String?
  twinPredictionAccuracy Float?
  /// JSON: { agentName, claimsMade, claimsValidated, score }[]
  agentAccuracyScores    Json      @default("[]")
  overallEfficacy        Float?
  reflectedAt            DateTime?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  user     User      @relation("ProtocolOutcomeUser", fields: [userId], references: [id], onDelete: Cascade)
  protocol Protocol? @relation("ProtocolOutcomeProtocol", fields: [protocolId], references: [id], onDelete: SetNull)
  cycle    LoopCycle @relation("LoopCycleOutcome", fields: [loopCycleId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([loopCycleId])
}

/// A scheduled, user-facing reminder (e.g. re-measure your panel). Surfaced
/// in-app when due; a job can later fan out to email/push from the same rows.
model Reminder {
  id        String   @id @default(cuid())
  userId    String
  tenantId  String   @default("default")
  kind      String // e.g. "REMEASURE"
  title     String
  detail    String?
  dueAt      DateTime
  status     String    @default("PENDING") // PENDING | DONE | DISMISSED
  notifiedAt DateTime? // set once the delivery job has fanned it out
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  user User @relation("ReminderUser", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status, dueAt])
  @@index([tenantId, status, dueAt])
}

/// LLM-generated retrospective analysis of a completed loop cycle.
/// Persisted with a W3C VC receipt; labeled research analysis, not medical advice.
model ReflectionReport {
  id                String   @id @default(cuid())
  userId            String
  tenantId          String   @default("default")
  loopCycleId       String   @unique
  protocolOutcomeId String?
  /// JSON: string[]
  insights          Json     @default("[]")
  /// JSON: Record<string, number> — agentName → accuracy score delta
  agentScoreDeltas  Json     @default("{}")
  twinAccuracyDelta Float?
  /// JSON: { compoundId, outcomeKey, observedDeltaPct, recommendedPriorAdjustment }[]
  priorAdjustments  Json     @default("[]")
  disclaimer        String   @default("Retrospective research analysis — not medical advice.")
  signedVc          Json?
  createdAt         DateTime @default(now())

  user  User      @relation("ReflectionReportUser", fields: [userId], references: [id], onDelete: Cascade)
  cycle LoopCycle @relation("LoopCycleReflection", fields: [loopCycleId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

/// Per-user, per-compound Bayesian priors for the digital twin fallback simulator.
/// Personalises the deterministic fallback when the mechanistic sidecar is unavailable.
model UserTwinPrior {
  id                String   @id @default(cuid())
  userId            String
  tenantId          String   @default("default")
  compoundId        String
  outcomeKey        String
  /// Personalized prior: target delta percentage
  prior             Float
  /// Population default — stored at creation for bounding calculations
  populationDefault Float
  /// Number of observed cycles that contributed to this prior
  n                 Int      @default(0)
  updatedAt         DateTime @updatedAt
  createdAt         DateTime @default(now())

  user User @relation("UserTwinPriorUser", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, compoundId, outcomeKey])
  @@index([userId])
}

// ─── Tier 4: Protocol version system ─────────────────────────────────────────

enum ProtocolVersionStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  REJECTED
  APPLIED
}

/// Immutable audit trail for every autonomous protocol change drafted by the
/// planning loop. Status progresses DRAFT → PENDING_APPROVAL → APPROVED → APPLIED.
/// The live Protocol row is NOT modified until status = APPLIED.
model ProtocolVersion {
  id                        String                @id @default(cuid())
  protocolId                String
  userId                    String
  tenantId                  String                @default("default")
  /// Auto-incrementing version number per protocol (1-based)
  version                   Int
  status                    ProtocolVersionStatus @default(DRAFT)
  /// JSON: { field, previousValue, newValue, rationale }[]
  changes                   Json                  @default("[]")
  /// Which agent session generated this draft
  generatedByAgentSessionId String?
  approvedBy                String?
  approvedAt                DateTime?
  appliedAt                 DateTime?
  createdAt                 DateTime              @default(now())
  updatedAt                 DateTime              @updatedAt

  protocol Protocol @relation("ProtocolVersions", fields: [protocolId], references: [id], onDelete: Cascade)
  user     User     @relation("ProtocolVersionUser", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([protocolId, version])
  @@index([protocolId, status])
  @@index([userId, createdAt])
}

// ─── Tier 5: Per-user pharmacokinetic profiles ───────────────────────────────

/// Fitted 1-compartment PK parameters for a specific user × compound pair.
/// Parameters are derived from ≥ 2 completed ProtocolOutcome records and
/// improve the digital twin accuracy over successive cycles.
/// Falls back to population defaults (PBPK_DEFAULTS) when no profile exists.
model UserPkProfile {
  id                   String   @id @default(cuid())
  userId               String
  tenantId             String   @default("default")
  compoundId           String
  /// Volume of distribution (L)
  vd                   Float
  /// Clearance (L/h)
  cl                   Float
  /// First-order absorption rate (h⁻¹)
  ka                   Float
  /// Oral bioavailability (0–1)
  f                    Float    @default(0.7)
  /// Number of ProtocolOutcome observations used to fit
  n                    Int
  /// Root-mean-square error of the fitted model vs observed data
  rmse                 Float
  fittedAt             DateTime @default(now())
  /// JSON array of ProtocolOutcome IDs used in the fit
  fittedFromOutcomeIds Json     @default("[]")
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  user User @relation("UserPkProfileUser", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, compoundId])
  @@index([userId])
  @@index([compoundId])
}

// ─── Moat M1: Federated Longitudinal Biomarker Graph ─────────────────────────

/// A federation node represents a clinic, lab, or partner institution
/// that contributes de-identified biomarker data to the federated graph.
model FederatedNode {
  id           String              @id @default(cuid())
  tenantId     String              @default("default")
  name         String
  jurisdiction String // ISO country code (e.g. "US", "DE")
  endpoint     String? // node API endpoint (optional for push nodes)
  publicKey    String? // node public key for encrypted sync
  active       Boolean             @default(true)
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  consents     FederationConsent[]

  @@index([tenantId, active])
  @@index([jurisdiction])
}

/// A user's consent to contribute their de-identified data to a
/// specific federated node's aggregate queries.
model FederationConsent {
  id        String        @id @default(cuid())
  userId    String
  nodeId    String
  tenantId  String        @default("default")
  /// Consent scope: which data categories the user has consented to share
  scope     Json          @default("[]")
  grantedAt DateTime      @default(now())
  revokedAt DateTime?
  user      User          @relation("FederationConsentUser", fields: [userId], references: [id], onDelete: Cascade)
  node      FederatedNode @relation(fields: [nodeId], references: [id])

  @@unique([userId, nodeId])
  @@index([userId])
  @@index([nodeId, revokedAt])
}

/// Per-user monthly differential privacy budget tracker.
/// Deducted on each aggregate query that uses this user's data.
/// Default: ε_max = 4.0 per user per calendar month.
model UserPrivacyBudget {
  id          String   @id @default(cuid())
  userId      String   @unique
  tenantId    String   @default("default")
  epsilonUsed Float    @default(0)
  epsilonMax  Float    @default(4.0)
  queryCount  Int      @default(0)
  periodStart DateTime // first day of current budget period
  periodEnd   DateTime // last day of current budget period (periodStart + 30 days)
  updatedAt   DateTime @updatedAt
  createdAt   DateTime @default(now())
  user        User     @relation("UserPrivacyBudget", fields: [userId], references: [id], onDelete: Cascade)

  @@index([periodEnd])
}

// ─── Moat M2: Protocol Fork Social Graph ────────────────────────────────────

/// Records when a user forks a protocol from another user's protocol.
/// Enables the GitHub-for-protocols moat: outcome data propagates
/// back to the source protocol's aggregate ledger (anonymised).
model ProtocolFork {
  id               String   @id @default(cuid())
  sourceProtocolId String
  forkedByUserId   String
  forkNote         String?
  createdAt        DateTime @default(now())

  sourceProtocol Protocol @relation(fields: [sourceProtocolId], references: [id], onDelete: Cascade)
  forkedBy       User     @relation("ProtocolForkUser", fields: [forkedByUserId], references: [id], onDelete: Cascade)

  @@index([sourceProtocolId])
  @@index([forkedByUserId])
}

// ─── Moat M3: Researcher Cohort Query DSL ────────────────────────────────────

/// IRB approval token for a researcher. Required to execute cohort DSL queries.
model IrbApproval {
  id          String    @id @default(cuid())
  userId      String
  tenantId    String    @default("default")
  token       String    @unique @default(cuid())
  institution String
  studyId     String
  approvedAt  DateTime  @default(now())
  expiresAt   DateTime
  revokedAt   DateTime?
  createdAt   DateTime  @default(now())
  user        User      @relation("IrbApprovalUser", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
  @@index([token])
}

// ─── Moat M7: Clinician Co-Sign Premium Tier ─────────────────────────────────

/// Auditable co-sign record from a licensed clinician on any AI-generated result.
/// Co-signing upgrades YELLOW-tier recommendations to provisional approval and
/// creates an auditable liability-transfer record.
model ClinicianCoSign {
  id                String    @id @default(cuid())
  resourceType      String // "DosageSuggestion" | "InvestigationPlan" | "CycleReport" …
  resourceId        String // ID of the signed resource
  clinicianId       String
  tenantId          String    @default("default")
  /// Clinician's digital signature (base64 of SHA-256 of resourceType+resourceId+clinicianId+signedAt)
  signature         String
  signedAt          DateTime  @default(now())
  expiresAt         DateTime?
  jurisdiction      String? // ISO country code
  licenseNumber     String
  licenseVerifiedAt DateTime?
  notes             String?
  createdAt         DateTime  @default(now())
  clinician         User      @relation("ClinicianCoSignUser", fields: [clinicianId], references: [id], onDelete: Cascade)

  @@index([resourceType, resourceId])
  @@index([clinicianId])
  @@index([signedAt])
}
