generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum UserRole {
  MEMBER
  ADMIN
  CLINICIAN
  RESEARCHER
}

enum OrganizationMembershipRole {
  OWNER
  ADMIN
  MEMBER
  VIEWER
}

enum ReviewStatus {
  OPEN
  IN_REVIEW
  RESOLVED
  DISMISSED
}

enum ReviewSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum SubscriptionStatus {
  INACTIVE
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
}

enum BillingRecordCategory {
  AI_CREDIT_PACK
  AI_CREDIT_USAGE
  TELEMEDICINE_CONSULTATION
  LAB_ORDER
}

enum BillingRecordStatus {
  PENDING
  PAID
  FAILED
  VOIDED
}

enum AICreditSource {
  SUBSCRIPTION_ALLOWANCE
  PURCHASED_TOP_UP
  ENTERPRISE_POOL
}

enum BiomarkerTrend {
  UP
  DOWN
  STABLE
}

enum IdempotencyExecutionStatus {
  PENDING
  COMPLETED
  FAILED
}

enum DependencyCircuitBreakerState {
  CLOSED
  OPEN
  HALF_OPEN
}

enum OrchestrationJobQueue {
  AI
  INGESTION
  NOTIFICATION
  GOVERNANCE
}

enum OrchestrationJobStatus {
  QUEUED
  LEASED
  SUCCEEDED
  FAILED
  DEAD_LETTER
  CANCELED
}

model User {
  id             String          @id @default(cuid())
  name           String?
  email          String          @unique
  emailVerified  DateTime?
  passwordHash   String
  stripeCustomerId String?       @unique
  role           UserRole        @default(MEMBER)
  discoveryTier  String?         @default("explorer") // explorer | pro | enterprise
  defaultTenantId String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  accounts       Account[]
  auditLogs      AuditLog[]
  profile        UserProfile?
  consentGrant   UserConsentGrant?
  biomarkers     Biomarker[]
  protocols      Protocol[]
  reviewItems    ReviewItem[]    @relation("ReviewedByUser")
  sessions       Session[]
  subscriptions  Subscription[]
  billingRecords BillingRecord[]
  researchCollections ResearchCollection[]
  clinicianTasks      ClinicianTask[]
  partnerDataRecords  PartnerDataRecord[]
  communityPosts      CommunityPost[]
  learnArticles       LearnArticle[]
  labOrders           LabOrder[]
  consultations       ConsultationRequest[]
  adverseEventReports AdverseEventReport[]
  marketplaceOrders   MarketplaceOrder[]
  evidenceRecords     EvidenceRecord[]       @relation("EvidenceCreatedBy")
  reviewedEvidence    EvidenceRecord[]       @relation("EvidenceReviewedBy")
  assignedEvidence    EvidenceRecord[]       @relation("EvidenceAssignedReviewer")
  evidenceReviewEvents EvidenceReviewEvent[] @relation("EvidenceReviewActor")
  ownedHypotheses     Hypothesis[]           @relation("HypothesisOwner")
  ownedCohorts        PatientCohort[]        @relation("CohortOwner")
  interventionOutcomes InterventionOutcome[]
  trialMatches        TrialMatch[]           @relation("TrialMatchUser")
  reviewedTrialMatches TrialMatch[]          @relation("TrialMatchReviewer")
  trialMatchReviewEvents TrialMatchReviewEvent[] @relation("TrialMatchReviewActor")
  aiResearchRuns      AIResearchRun[]
  createdMechanisticModels MechanisticModel[] @relation("UserCreatedMechanisticModels")
  aeonForgeCandidates AeonForgeCandidate[]
  marketplaceScientistProfile MarketplaceScientist? @relation("MarketplaceScientistUser")
  marketplaceSponsorProfile MarketplaceSponsor? @relation("MarketplaceSponsorUser")
  marketplaceSentMessages MarketplaceMessageThread[] @relation("MarketplaceMessageSender")
  marketplaceAuditEvents MarketplaceAuditLog[] @relation("MarketplaceAuditActor")
  marketplaceNotifications MarketplaceNotification[] @relation("MarketplaceNotificationRecipient")
  createdOrchestrationJobs OrchestrationJob[]    @relation("OrchestrationJobCreator")
  defaultTenant   Tenant?        @relation("UserDefaultTenant", fields: [defaultTenantId], references: [id], onDelete: SetNull)
  organizationMemberships OrganizationMembership[]
  mfaSecret       UserMfaSecret?
  activeSessions  ActiveSession[]
  trustScores     TrustScore[]   @relation("TrustScoreUser")
  timelineEntries TimelineEntry[] @relation("TimelineEntryUser")
  feedbackLoopSnapshots FeedbackLoopSnapshot[] @relation("FeedbackLoopUser")
  biologicalAgeSnapshots BiologicalAgeSnapshot[] @relation("BioAgeUser")
  userXP              UserXP?            @relation("UserXPUser")
  userStreaks          UserStreak[]       @relation("UserStreakUser")
  userAchievements    UserAchievement[]  @relation("UserAchievementUser")
  wearableConnections WearableConnection[] @relation("WearableConnectionUser")
  graphContributions  PendingGraphContribution[] @relation("GraphContributionUser")
  apiKeys             APIKey[]           @relation("APIKeyUser")
  referralsSent       Referral[]         @relation("ReferralReferrer")
  referralsReceived   Referral[]         @relation("ReferralReferee")
  flParticipations    FLParticipation[]  @relation("FLParticipationUser")
  medications         Medication[]       @relation("MedicationUser")
  agentSessions       AgentSession[]     @relation("AgentSessionUser")
  driftSweeps         DriftSweep[]       @relation("DriftSweepUser")
  driftNotifications  DriftNotification[] @relation("DriftNotificationUser")
}

model UserMfaSecret {
  id          String   @id @default(cuid())
  userId      String   @unique
  secret      String
  verified    Boolean  @default(false)
  backupCodes Json?
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ActiveSession {
  id            String    @id @default(cuid())
  userId        String
  tokenHash     String    @unique
  userAgent     String?
  ipAddress     String?
  createdAt     DateTime  @default(now())
  lastActiveAt  DateTime  @default(now())
  revokedAt     DateTime?
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, revokedAt])
}

model Tenant {
  id              String                   @id @default(cuid())
  slug            String                   @unique
  name            String
  status          String                   @default("active")
  isolationMode   String                   @default("shared")
  createdAt       DateTime                 @default(now())
  updatedAt       DateTime                 @updatedAt
  organizations   Organization[]
  memberships     OrganizationMembership[]
  defaultUsers    User[]                   @relation("UserDefaultTenant")
  agentSessions AgentSession[]             @relation("AgentSessionTenant")

  @@index([status, isolationMode])
}

model Organization {
  id              String                   @id @default(cuid())
  tenantId        String
  name            String
  slug            String                   @unique
  type            String                   @default("enterprise")
  status          String                   @default("active")
  createdAt       DateTime                 @default(now())
  updatedAt       DateTime                 @updatedAt
  tenant          Tenant                   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  memberships     OrganizationMembership[]
  sponsorProfiles MarketplaceSponsor[]

  @@index([tenantId, status])
}

model OrganizationMembership {
  id             String                     @id @default(cuid())
  tenantId       String
  organizationId String
  userId         String
  role           OrganizationMembershipRole @default(MEMBER)
  status         String                     @default("active")
  isDefault      Boolean                    @default(false)
  createdAt      DateTime                   @default(now())
  updatedAt      DateTime                   @updatedAt
  tenant         Tenant                     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  organization   Organization               @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User                       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
  @@index([tenantId, userId, role])
}

model UserProfile {
  id                    String   @id @default(cuid())
  tenantId              String   @default("default")
  userId                String   @unique
  dateOfBirth           DateTime?
  biologicalSex         String?
  longevityGoal         String?
  riskTolerance         String?
  // Onboarding fields
  dietaryPattern        String?  // omnivore, vegetarian, vegan, keto, mediterranean, paleo, other
  activityLevel         String?  // sedentary, light, moderate, active, very_active
  sleepQuality          Int?     // 1-5
  stressLevel           Int?     // 1-5
  healthConditions      String   @default("[]") // JSON array of condition strings
  supplementStack       String   @default("[]") // JSON array of supplement strings
  healthGoals           String   @default("[]") // JSON array: cognitive, cardiovascular, metabolic, athletic, aesthetic
  primaryMotivation     String?
  onboardingCompletedAt DateTime?
  // Notification preferences
  timezone              String?  // IANA timezone, e.g. "America/New_York"
  quietHoursStart       Int?     // 0-23, local hour when quiet hours begin
  quietHoursEnd         Int?     // 0-23, local hour when quiet hours end
  driftNotificationsOn  Boolean  @default(true) // master toggle for drift alerts
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model UserConsentGrant {
  id               String   @id @default(cuid())
  tenantId         String   @default("default")
  userId           String   @unique
  status           String   @default("active")
  legalBasis       String?
  scopes           Json
  gdprConsents     Json?    /// GDPR consent categories: data-processing, ai-health-info, research-usage
  consentVersion   Int      @default(1)
  effectiveAt      DateTime @default(now())
  expiresAt        DateTime?
  revokedAt        DateTime?
  revocationReason String?
  policyVersion    String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([status, updatedAt])
}

model Subscription {
  id               String             @id @default(cuid())
  tenantId         String             @default("default")
  userId           String
  plan             String
  status           SubscriptionStatus @default(INACTIVE)
  provider         String             @default("manual")
  priceCents       Int
  currency         String             @default("USD")
  billingCycle     String
  regionTier       String?
  seatQuantity     Int                @default(1)
  monthlyAICreditAllowance Int?
  stripeCheckoutSessionId String?     @unique
  stripeSubscriptionId String?        @unique
  currentPeriodEnd DateTime?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  user             User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([regionTier, createdAt])
}

model BillingRecord {
  id                   String                @id @default(cuid())
  tenantId             String                @default("default")
  userId               String
  category             BillingRecordCategory
  status               BillingRecordStatus   @default(PENDING)
  description          String
  amountCents          Int
  currency             String                @default("USD")
  quantity             Int                   @default(1)
  regionTier           String?
  pricingModel         String?
  aiCreditPackKey      String?
  aiCreditSource       AICreditSource?
  aiCreditsDelta       Int                   @default(0)
  stripeCheckoutSessionId String?            @unique
  stripePaymentIntentId   String?            @unique
  consultationRequestId   String?            @unique
  labOrderId              String?            @unique
  paidAt               DateTime?
  metadata             Json?
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt

  user                 User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  consultationRequest  ConsultationRequest?  @relation(fields: [consultationRequestId], references: [id], onDelete: SetNull)
  labOrder             LabOrder?             @relation(fields: [labOrderId], references: [id], onDelete: SetNull)

  @@index([tenantId, category, status])
  @@index([userId, createdAt])
  @@index([userId, aiCreditSource, status, createdAt])
  @@index([regionTier, createdAt])
}

model Biomarker {
  id         String         @id @default(cuid())
  tenantId   String         @default("default")
  userId     String
  name       String
  value      Float
  unit       String
  target     Float?
  trend      BiomarkerTrend @default(STABLE)
  source     String?        // Origin: null=manual, "lab:provider", "wearable:oura", etc.
  measuredAt DateTime       @default(now())
  createdAt  DateTime       @default(now())
  protocolId String?        // Link to protocol/intervention period
  user       User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  protocol   Protocol?      @relation(fields: [protocolId], references: [id], onDelete: SetNull)

  @@index([userId, measuredAt])
  @@index([tenantId, userId])
}

model Protocol {
  id          String   @id @default(cuid())
  tenantId    String   @default("default")
  userId      String
  name        String
  status      String   @default("draft")
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  outcomes    InterventionOutcome[]
  contraindicationScore Float? // Aggregate safety/contraindication score
  biomarkerMeasurements Biomarker[]
  labResults LabResult[]
  adverseEventReports AdverseEventReport[]
  aggregateOutcomes AggregateOutcome[] @relation("AggregateOutcomeProtocol")

  @@index([userId, updatedAt])
  @@index([tenantId, userId])
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?
  access_token       String?
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?
  session_state      String?
  user               User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model AuditLog {
  id          String   @id @default(cuid())
  actorUserId String?
  actorEmail  String?
  tenantId    String   @default("default")
  action      String
  entityType  String
  entityId    String?
  details     String?
  prevHash    String?
  entryHash   String?
  createdAt   DateTime @default(now())
  actorUser   User?    @relation(fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([tenantId, createdAt])
  @@index([entityType, entityId])
}

model IdempotencyRecord {
  id                 String                      @id @default(cuid())
  tenantId           String
  route              String
  method             String
  key                String
  actorUserId        String?
  requestFingerprint String
  status             IdempotencyExecutionStatus @default(PENDING)
  responseStatus     Int?
  responseBody       Json?
  errorMessage       String?
  completedAt        DateTime?
  expiresAt          DateTime?
  createdAt          DateTime                    @default(now())
  updatedAt          DateTime                    @updatedAt

  @@unique([tenantId, route, method, key])
  @@index([tenantId, status, expiresAt])
  @@index([actorUserId, createdAt])
}

model DependencyCircuitBreaker {
  id            String                         @id @default(cuid())
  dependency    String                         @unique
  state         DependencyCircuitBreakerState  @default(CLOSED)
  failureCount  Int                            @default(0)
  successCount  Int                            @default(0)
  lastFailureAt DateTime?
  lastSuccessAt DateTime?
  openedAt      DateTime?
  nextAttemptAt DateTime?
  lastError     String?
  createdAt     DateTime                       @default(now())
  updatedAt     DateTime                       @updatedAt

  @@index([state, nextAttemptAt])
}

model ReviewItem {
  id                String         @id @default(cuid())
  tenantId          String         @default("default")
  title             String
  category          String
  status            ReviewStatus   @default(OPEN)
  severity          ReviewSeverity @default(MEDIUM)
  details           String?
  relatedEntityType String?
  relatedEntityId   String?
  reviewedByUserId  String?
  reviewedAt        DateTime?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  reviewedByUser    User?          @relation("ReviewedByUser", fields: [reviewedByUserId], references: [id], onDelete: SetNull)

  @@index([status, severity])
}

// ─── Enterprise research & clinical data models ─────────────

enum ResearchSource {
  PUBMED
  MANUAL
  IMPORT
}

enum EvidenceStudyType {
  IN_VITRO
  ANIMAL
  OBSERVATIONAL
  CASE_SERIES
  RCT
  META_ANALYSIS
  SYSTEMATIC_REVIEW
  MECHANISTIC
  EXPERT_OPINION
}

enum EvidenceDirection {
  SUPPORTIVE
  MIXED
  NEUTRAL
  CONTRADICTORY
}

enum EvidenceReviewStatus {
  AUTO_QUEUED
  IN_REVIEW
  VERIFIED
  REJECTED
  ESCALATED
}

enum EvidenceProvenanceType {
  MANUAL
  PUBMED_IMPORT
  CLINICAL_TRIAL_IMPORT
  USER_CURATED
  AI_EXTRACTED
}

enum EvidenceReviewEventType {
  ASSIGNED
  STATUS_UPDATED
  NOTES_UPDATED
}

enum HypothesisStatus {
  DRAFT
  PRIORITIZED
  IN_REVIEW
  VALIDATED
  REJECTED
}

enum TrialMatchStatus {
  CANDIDATE
  REVIEWED
  CONTACTED
  ENROLLED
  ARCHIVED
}

enum AIWorkflowType {
  LITERATURE_REVIEW
  HYPOTHESIS_GENERATION
  SAFETY_REVIEW
  COHORT_ANALYSIS
  TRIAL_MATCHING
}

enum ClinicianTaskStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELED
}

enum PartnerDataSource {
  LAB
  WEARABLE
  GENOMICS
  CUSTOM
}

enum CohortRiskBand {
  LOW
  MODERATE
  HIGH
  COMPLEX
}

model ResearchCollection {
  id          String            @id @default(cuid())
  tenantId    String            @default("default")
  userId      String
  name        String
  description String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  entries     ResearchEntry[]
  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model ResearchEntry {
  id           String           @id @default(cuid())
  collectionId String
  source       ResearchSource   @default(MANUAL)
  externalId   String?
  title        String
  authors      String?
  abstract     String?
  url          String?
  publishedAt  DateTime?
  createdAt    DateTime         @default(now())
  collection   ResearchCollection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  evidenceRecords EvidenceRecord[]

  @@index([collectionId])
  @@index([source, externalId])
}

model EvidenceRecord {
  id                  String            @id @default(cuid())
  createdByUserId     String?
  reviewedByUserId    String?
  assignedReviewerId  String?
  researchEntryId     String?
  title               String
  diseaseArea         String?
  sourceLabel         String
  externalId          String?
  sourceUrl           String?
  abstract            String?
  populationSummary   String?
  interventionSummary String?
  outcomeSummary      String?
  biomarkerTargets    String?
  contraindications   String?
  studyType           EvidenceStudyType
  evidenceDirection   EvidenceDirection @default(SUPPORTIVE)
  reviewStatus        EvidenceReviewStatus @default(AUTO_QUEUED)
  provenanceType      EvidenceProvenanceType @default(MANUAL)
  provenanceDetail    String?
  automationSource    String?
  evidenceScore       Float             @default(0)
  uncertaintyScore    Float             @default(0.5)
  reviewConfidence    Float             @default(0.5)
  sourceCapturedAt    DateTime?
  reviewed            Boolean           @default(false)
  verificationNotes   String?
  reviewedAt          DateTime?
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt

  createdByUser       User?             @relation("EvidenceCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  reviewedByUser      User?             @relation("EvidenceReviewedBy", fields: [reviewedByUserId], references: [id], onDelete: SetNull)
  assignedReviewer    User?             @relation("EvidenceAssignedReviewer", fields: [assignedReviewerId], references: [id], onDelete: SetNull)
  researchEntry       ResearchEntry?    @relation(fields: [researchEntryId], references: [id], onDelete: SetNull)
  hypotheses          HypothesisEvidence[]
  reviewEvents        EvidenceReviewEvent[]
  priorityChanges     HypothesisPriorityChange[]

  @@index([diseaseArea, studyType])
  @@index([reviewed, evidenceScore])
  @@index([reviewStatus, provenanceType])
  @@index([assignedReviewerId, reviewStatus])
}

model Hypothesis {
  id                     String            @id @default(cuid())
  ownerUserId            String
  title                  String
  question               String
  targetCondition        String?
  rationale              String
  proposedMechanism      String?
  suggestedTests         String?
  suggestedInterventions String?
  cohortDefinition       String?
  priorityScore          Float             @default(0.25)
  averageEvidenceScore   Float             @default(0.25)
  evidenceCoverageScore  Float             @default(0)
  contraindicationScore  Float             @default(0.25)
  confidenceScore        Float             @default(0.5)
  uncertaintyScore       Float             @default(0.5)
  status                 HypothesisStatus  @default(DRAFT)
  createdAt              DateTime          @default(now())
  updatedAt              DateTime          @updatedAt

  ownerUser              User              @relation("HypothesisOwner", fields: [ownerUserId], references: [id], onDelete: Cascade)
  evidenceLinks          HypothesisEvidence[]
  priorityChanges        HypothesisPriorityChange[]

  @@index([ownerUserId, status])
}

model EvidenceReviewEvent {
  id                         String                  @id @default(cuid())
  evidenceRecordId           String
  actorUserId                String
  eventType                  EvidenceReviewEventType
  previousStatus             EvidenceReviewStatus?
  nextStatus                 EvidenceReviewStatus?
  previousAssignedReviewerId String?
  nextAssignedReviewerId     String?
  notes                      String?
  createdAt                  DateTime                @default(now())

  evidenceRecord             EvidenceRecord          @relation(fields: [evidenceRecordId], references: [id], onDelete: Cascade)
  actorUser                  User                    @relation("EvidenceReviewActor", fields: [actorUserId], references: [id], onDelete: Cascade)
  hypothesisChanges          HypothesisPriorityChange[]

  @@index([evidenceRecordId, createdAt])
  @@index([actorUserId, eventType])
}

model HypothesisPriorityChange {
  id                       String              @id @default(cuid())
  hypothesisId             String
  evidenceReviewEventId    String
  evidenceRecordId         String
  previousPriorityScore    Float
  newPriorityScore         Float
  previousConfidenceScore  Float
  newConfidenceScore       Float
  previousStatus           HypothesisStatus
  newStatus                HypothesisStatus
  delta                    Float
  rationale                String?
  createdAt                DateTime            @default(now())

  hypothesis               Hypothesis          @relation(fields: [hypothesisId], references: [id], onDelete: Cascade)
  evidenceReviewEvent      EvidenceReviewEvent @relation(fields: [evidenceReviewEventId], references: [id], onDelete: Cascade)
  evidenceRecord           EvidenceRecord      @relation(fields: [evidenceRecordId], references: [id], onDelete: Cascade)

  @@index([hypothesisId, createdAt])
  @@index([evidenceRecordId, createdAt])
}

model HypothesisEvidence {
  id               String         @id @default(cuid())
  hypothesisId     String
  evidenceRecordId String
  weight           Float          @default(1)
  rationale        String?
  createdAt        DateTime       @default(now())

  hypothesis       Hypothesis     @relation(fields: [hypothesisId], references: [id], onDelete: Cascade)
  evidenceRecord   EvidenceRecord @relation(fields: [evidenceRecordId], references: [id], onDelete: Cascade)

  @@unique([hypothesisId, evidenceRecordId])
}

model PatientCohort {
  id                String       @id @default(cuid())
  tenantId          String       @default("default")
  ownerUserId       String
  name              String
  focusArea         String
  inclusionCriteria String
  exclusionCriteria String?
  biomarkerFocus    String?
  cohortSize        Int          @default(0)
  stratificationAxes String?
  stratificationSummary String?
  estimatedEligibleShare Float   @default(0)
  confidenceScore   Float        @default(0.5)
  readinessScore    Float        @default(0)
  riskBand          CohortRiskBand @default(MODERATE)
  outcomeSummary    String?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  ownerUser         User         @relation("CohortOwner", fields: [ownerUserId], references: [id], onDelete: Cascade)
  trialMatches      TrialMatch[]

  @@index([ownerUserId, focusArea])
}

model AIResearchRun {
  id               String         @id @default(cuid())
  tenantId         String         @default("default")
  userId           String
  workflowType     AIWorkflowType
  inputSummary     String
  outputSummary    String
  citations        String?
  uncertaintyScore Float          @default(0.5)
  createdAt        DateTime       @default(now())

  user             User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, workflowType])
}

model ClinicianTask {
  id          String              @id @default(cuid())
  tenantId    String              @default("default")
  userId      String
  title       String
  description String?
  status      ClinicianTaskStatus @default(PENDING)
  priority    Int                 @default(0)
  dueAt       DateTime?
  completedAt DateTime?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  user        User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
}

model Medication {
  id             String   @id @default(cuid())
  tenantId       String   @default("default")
  userId         String
  name           String
  dosage         String?
  frequency      String?  // e.g. "once daily", "twice daily"
  prescribedFor  String?  // condition or reason
  category       String   @default("supplement") // supplement, prescription, otc
  active         Boolean  @default(true)
  startedAt      DateTime @default(now())
  discontinuedAt DateTime?
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  user           User     @relation("MedicationUser", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, active])
  @@index([tenantId, userId])
}

model PartnerDataRecord {
  id         String            @id @default(cuid())
  tenantId   String            @default("default")
  userId     String
  source     PartnerDataSource
  partnerId  String?
  label      String
  payload    String
  receivedAt DateTime          @default(now())
  createdAt  DateTime          @default(now())
  user       User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, source])
}

// ─── Knowledge Graph: Longevity Science Ontology ─────────────

model Compound {
  id            String       @id @default(cuid())
  name          String       @unique
  aliases       String?      // JSON array of alternative names
  category      String       // e.g. "peptide", "small-molecule", "supplement", "drug"
  riskCategory  RiskCategory @default(GREEN)
  description   String?
  casNumber     String?      @unique
  pubChemCid    String?
  mechanism     String?      // brief mechanism of action
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  pathways          CompoundPathway[]
  interactions      CompoundInteraction[] @relation("CompoundA")
  interactedWith    CompoundInteraction[] @relation("CompoundB")
  biomarkerEffects  CompoundBiomarkerEffect[]
  studyLinks        CompoundStudyLink[]
  aggregateOutcomes AggregateOutcome[] @relation("AggregateOutcomeCompound")
}

model Pathway {
  id          String   @id @default(cuid())
  name        String   @unique
  category    String   // e.g. "aging", "metabolic", "epigenetic", "inflammatory"
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  compounds   CompoundPathway[]
}

model CompoundPathway {
  id          String   @id @default(cuid())
  compoundId  String
  pathwayId   String
  effect      String   // "activator", "inhibitor", "modulator"
  strength    String?  // "strong", "moderate", "weak", "theoretical"
  evidence    String?  // free-text evidence summary
  createdAt   DateTime @default(now())

  compound    Compound @relation(fields: [compoundId], references: [id], onDelete: Cascade)
  pathway     Pathway  @relation(fields: [pathwayId], references: [id], onDelete: Cascade)

  @@unique([compoundId, pathwayId])
}

enum InteractionSeverity {
  BENEFICIAL
  NEUTRAL
  CAUTION
  DANGEROUS
  UNKNOWN
}

model CompoundInteraction {
  id             String              @id @default(cuid())
  compoundAId    String
  compoundBId    String
  severity       InteractionSeverity @default(UNKNOWN)
  description    String?
  source         String?             // citation or source URL
  createdAt      DateTime            @default(now())

  compoundA      Compound @relation("CompoundA", fields: [compoundAId], references: [id], onDelete: Cascade)
  compoundB      Compound @relation("CompoundB", fields: [compoundBId], references: [id], onDelete: Cascade)

  @@unique([compoundAId, compoundBId])
}

model CompoundBiomarkerEffect {
  id            String   @id @default(cuid())
  compoundId    String
  biomarkerName String   // e.g. "HbA1c", "CRP", "telomere length"
  direction     String   // "increase", "decrease", "stabilize"
  magnitude     String?  // "significant", "moderate", "mild"
  evidence      String?  // summary
  source        String?  // citation
  createdAt     DateTime @default(now())

  compound      Compound @relation(fields: [compoundId], references: [id], onDelete: Cascade)

  @@index([compoundId])
  @@index([biomarkerName])
}

model CompoundStudyLink {
  id            String   @id @default(cuid())
  compoundId    String
  externalId    String   // PubMed ID, NCT ID, DOI, etc.
  source        String   // "pubmed", "clinicaltrials", "doi"
  title         String?
  url           String?
  createdAt     DateTime @default(now())

  compound      Compound @relation(fields: [compoundId], references: [id], onDelete: Cascade)

  @@unique([compoundId, source, externalId])
}


// ─── Mechanistic Model Registry ────────────────────────────

model MechanisticModel {
  id            String   @id @default(cuid())
  tenantId      String   @default("default")
  name          String
  description   String?
  version       String   // e.g. "v1.0.0"
  source        String?  // e.g. "manual", "imported", "AI-generated"
  createdById   String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  createdBy     User?    @relation("UserCreatedMechanisticModels", fields: [createdById], references: [id], onDelete: SetNull)
  confidenceScores ModelConfidenceScore[]

  @@unique([name, version])
}

model ModelConfidenceScore {
  id                  String   @id @default(cuid())
  mechanisticModelId  String
  entityType          String   // e.g. "Hypothesis", "Protocol", "Cohort", etc.
  entityId            String   // ID of the entity the score applies to
  score               Float    // Confidence score (0-1)
  rationale           String?
  version             String   // Model version used for this score
  createdAt           DateTime @default(now())

  mechanisticModel    MechanisticModel @relation(fields: [mechanisticModelId], references: [id], onDelete: Cascade)

  @@index([entityType, entityId])
  @@index([mechanisticModelId, version])
}

