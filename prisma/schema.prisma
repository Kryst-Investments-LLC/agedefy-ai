  outcomeSummary         String?
  createdAt              DateTime       @default(now())
  updatedAt              DateTime       @updatedAt

  ownerUser    User         @relation("CohortOwner", fields: [ownerUserId], references: [id], onDelete: Cascade)
  trialMatches TrialMatch[]

  @@index([ownerUserId, focusArea])
}

model AIResearchRun {
